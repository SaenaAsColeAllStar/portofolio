---
// ArchitectureIcon.astro - Isometric Cube / Grid icon
interface Props {
	size?: number | string;
	class?: string;
}
const { size = 24, class: className = "" } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className}>
	<polygon points="12,2 22,8.5 22,15.5 12,22 2,15.5 2,8.5" />
	<line x1="12" y1="22" x2="12" y2="12" />
	<line x1="12" y1="12" x2="22" y2="8.5" />
	<line x1="12" y1="12" x2="2" y2="8.5" />
	<line x1="2" y1="15.5" x2="12" y2="12" />
	<line x1="22" y1="15.5" x2="12" y2="12" />
	<line x1="12" y1="2" x2="12" y2="12" />
</svg>
