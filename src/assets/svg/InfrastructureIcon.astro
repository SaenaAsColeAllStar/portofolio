---
// InfrastructureIcon.astro - Server Stack icon
interface Props {
	size?: number | string;
	class?: string;
}
const { size = 24, class: className = "" } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className}>
	<rect x="2" y="2" width="20" height="8" rx="2" />
	<rect x="2" y="14" width="20" height="8" rx="2" />
	<line x1="6" y1="6" x2="6.01" y2="6" stroke-width="3" />
	<line x1="6" y1="18" x2="6.01" y2="18" stroke-width="3" />
	<line x1="10" y1="6" x2="14" y2="6" />
	<line x1="10" y1="18" x2="14" y2="18" />
</svg>
