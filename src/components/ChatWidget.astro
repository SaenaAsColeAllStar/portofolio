---
// ChatWidget.astro - Floating AI Assistant Widget
---

<!-- Floating Chat Button -->
<button id="chat-widget-trigger" class="chat-trigger-btn" aria-label="Open AI Assistant">
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
  </svg>
  <span class="pulse-dot"></span>
</button>

<!-- Chat Window Wrapper -->
<div id="chat-widget-window" class="chat-window hidden">
  <!-- Window Header -->
  <div class="chat-header">
    <div class="header-info">
      <div class="glowing-status"></div>
      <div>
        <h3>CTOS System Assistant</h3>
        <span class="status-subtext">Online &bull; Llama 3.1 Edge</span>
      </div>
    </div>
    <button id="chat-widget-close" aria-label="Close Chat" class="close-btn">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Messages Area -->
  <div class="chat-messages" id="chat-messages-area">
    <!-- Initial welcome message -->
    <div class="message assistant">
      <div class="message-bubble">
        Hello! I am the CTOS System Assistant. Feel free to ask me about Saepul Husna's capabilities, projects, technical experience, or how to contact him.
      </div>
    </div>
  </div>

  <!-- Quick Suggestions -->
  <div class="chat-suggestions" id="chat-suggestions-container">
    <button class="suggestion-pill">What are your core capabilities?</button>
    <button class="suggestion-pill">Tell me about your projects.</button>
    <button class="suggestion-pill">How can I contact you?</button>
  </div>

  <!-- Chat Input -->
  <form id="chat-widget-form" class="chat-input-form">
    <input 
      type="text" 
      id="chat-user-input" 
      placeholder="Ask about CTOS architecture..." 
      autocomplete="off" 
      required 
    />
    <button type="submit" class="send-btn" aria-label="Send Message">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"></line>
        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
      </svg>
    </button>
  </form>
</div>

<style>
  /* Floating Button */
  .chat-trigger-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: var(--text, #fff);
    color: var(--bg, #0b111e);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), 0 0 12px rgba(255, 255, 255, 0.05);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 999;
    transition: transform 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.25s;
  }

  .chat-trigger-btn:hover {
    transform: scale(1.08) translateY(-2px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5), 0 0 20px rgba(255, 255, 255, 0.15);
  }

  .chat-trigger-btn:active {
    transform: scale(0.95);
  }

  .pulse-dot {
    position: absolute;
    top: 2px;
    right: 2px;
    width: 10px;
    height: 10px;
    background: #2ecc71;
    border-radius: 50%;
    border: 2px solid var(--text, #fff);
    animation: pulse 1.8s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(0.9); opacity: 1; }
    50% { transform: scale(1.25); box-shadow: 0 0 8px #2ecc71; }
    100% { transform: scale(0.9); opacity: 1; }
  }

  /* Chat Window (Glassmorphism) */
  .chat-window {
    position: fixed;
    bottom: 6.5rem;
    right: 2rem;
    width: 22rem;
    height: 30rem;
    background: rgba(18, 26, 44, 0.82);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border, rgba(255, 255, 255, 0.08));
    border-radius: 1.25rem;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.5);
    display: flex;
    flex-direction: column;
    z-index: 999;
    overflow: hidden;
    transition: opacity 0.25s cubic-bezier(0.165, 0.84, 0.44, 1), transform 0.25s cubic-bezier(0.165, 0.84, 0.44, 1);
    transform-origin: bottom right;
  }

  .chat-window.hidden {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.9) translateY(20px);
  }

  /* Header */
  .chat-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.015);
  }

  .header-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .glowing-status {
    width: 8px;
    height: 8px;
    background: #2ecc71;
    border-radius: 50%;
    box-shadow: 0 0 6px #2ecc71;
  }

  .chat-header h3 {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
  }

  .status-subtext {
    font-size: 0.75rem;
    color: var(--muted);
  }

  .close-btn {
    background: transparent;
    border: none;
    color: var(--muted);
    cursor: pointer;
    padding: 4px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, color 0.2s;
  }

  .close-btn:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--text);
  }

  /* Messages List */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .message {
    display: flex;
    flex-direction: column;
    max-width: 85%;
  }

  .message.user {
    align-self: flex-end;
  }

  .message.assistant {
    align-self: flex-start;
  }

  .message-bubble {
    padding: 0.75rem 1rem;
    border-radius: 1rem;
    font-size: 0.9rem;
    line-height: 1.45;
    word-break: break-word;
    white-space: pre-wrap;
  }

  .message.user .message-bubble {
    background: var(--text, #fff);
    color: var(--bg, #0b111e);
    border-bottom-right-radius: 0.25rem;
  }

  .message.assistant .message-bubble {
    background: rgba(255, 255, 255, 0.035);
    border: 1px solid var(--border);
    color: var(--text);
    border-bottom-left-radius: 0.25rem;
    white-space: normal;
    padding: 0.85rem 1.1rem;
    line-height: 1.6;
    font-size: 0.88rem;
  }

  /* Chat Markdown Elements Styling */
  .message-bubble p {
    margin: 0 0 0.65rem;
  }
  .message-bubble p:last-child {
    margin-bottom: 0;
  }

  .message-bubble h1,
  .message-bubble h2,
  .message-bubble h3 {
    color: var(--text);
    font-weight: 600;
    margin: 1.1rem 0 0.5rem;
    line-height: 1.25;
  }

  .message-bubble h1 { font-size: 1.2rem; }
  .message-bubble h2 { font-size: 1.08rem; }
  .message-bubble h3 { font-size: 1rem; }

  /* Lists */
  .message-bubble .chat-list {
    margin: 0.5rem 0 0.75rem 1.25rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .message-bubble .chat-list.ordered {
    list-style-type: decimal;
  }

  .message-bubble .chat-list.unordered {
    list-style-type: disc;
  }

  .message-bubble .chat-list li {
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--text);
  }

  /* Links */
  .chat-link {
    color: var(--accent, #4f8cff);
    text-decoration: underline;
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .chat-link:hover {
    opacity: 0.8;
  }

  /* Inline Code */
  .message-bubble :not(pre) > code {
    background: rgba(255, 255, 255, 0.08);
    padding: 0.15rem 0.35rem;
    border-radius: 4px;
    font-family: monospace;
    font-size: 0.82rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
    color: var(--accent, #4f8cff);
  }

  /* Code Block Styling */
  .chat-code-block {
    background: rgba(0, 0, 0, 0.45);
    border: 1px solid var(--border);
    border-radius: 8px;
    margin: 0.85rem 0;
    overflow: hidden;
    max-width: 100%;
  }

  .chat-code-header {
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid var(--border);
    padding: 0.35rem 0.75rem;
    font-size: 0.7rem;
    font-family: monospace;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .chat-code-block pre {
    margin: 0;
    padding: 0.75rem 0.9rem;
    overflow-x: auto;
  }

  .chat-code-block code {
    background: transparent;
    border: none;
    padding: 0;
    border-radius: 0;
    font-family: monospace;
    font-size: 0.8rem;
    color: #e2e8f0;
    white-space: pre;
    line-height: 1.45;
  }

  /* Suggestions */
  .chat-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    background: rgba(0, 0, 0, 0.05);
  }

  .suggestion-pill {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border);
    padding: 0.4rem 0.75rem;
    border-radius: 99px;
    font-size: 0.78rem;
    color: var(--muted);
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    text-align: left;
  }

  .suggestion-pill:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--text);
    border-color: var(--accent);
  }

  /* Form / Input */
  .chat-input-form {
    display: flex;
    padding: 0.85rem 1.25rem 1rem;
    gap: 0.75rem;
    border-top: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.01);
  }

  .chat-input-form input {
    flex: 1;
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid var(--border);
    border-radius: 99px;
    color: var(--text);
    font-family: inherit;
    font-size: 0.9rem;
    padding: 0.6rem 1.1rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .chat-input-form input:focus {
    border-color: var(--accent);
  }

  .send-btn {
    background: var(--text, #fff);
    color: var(--bg, #0b111e);
    border: none;
    width: 2.3rem;
    height: 2.3rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s, transform 0.1s;
  }

  .send-btn:hover {
    opacity: 0.9;
  }

  .send-btn:active {
    transform: scale(0.93);
  }

  /* Typing Indicator */
  .typing-indicator {
    display: flex;
    gap: 4px;
    padding: 0.5rem 0.75rem;
    align-items: center;
    justify-content: center;
    width: fit-content;
  }

  .typing-dot {
    width: 6px;
    height: 6px;
    background: var(--muted);
    border-radius: 50%;
    animation: typing 1.4s infinite ease-in-out;
  }

  .typing-dot:nth-child(1) { animation-delay: 0s; }
  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typing {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  /* Responsive styling */
  @media (max-width: 480px) {
    .chat-window {
      width: calc(100vw - 2rem);
      height: calc(100vh - 10rem);
      bottom: 5.5rem;
      right: 1rem;
    }
    .chat-trigger-btn {
      bottom: 1rem;
      right: 1rem;
    }
  }
</style>

<script>
  interface Message {
    role: 'user' | 'assistant';
    content: string;
  }

  function initChatWidget() {
    const trigger = document.getElementById('chat-widget-trigger');
    const windowEl = document.getElementById('chat-widget-window');
    const closeBtn = document.getElementById('chat-widget-close');
    const form = document.getElementById('chat-widget-form') as HTMLFormElement | null;
    const input = document.getElementById('chat-user-input') as HTMLInputElement | null;
    const messagesArea = document.getElementById('chat-messages-area');
    const suggestionsContainer = document.getElementById('chat-suggestions-container');

    if (!trigger || !windowEl || !closeBtn || !form || !input || !messagesArea) return;

    let chatHistory: Message[] = [];

    // Load history from SessionStorage if it exists
    const storedHistory = sessionStorage.getItem('ctos_chat_history');
    if (storedHistory) {
      try {
        chatHistory = JSON.parse(storedHistory);
        // Re-render message bubbles
        chatHistory.forEach(msg => {
          appendMessageBubble(msg.role, msg.content);
        });
      } catch (e) {
        console.error('Failed to load chat history', e);
      }
    }

    // Toggle Chat Window
    trigger.addEventListener('click', () => {
      windowEl.classList.toggle('hidden');
      if (!windowEl.classList.contains('hidden')) {
        input.focus();
        scrollToBottom();
      }
    });

    closeBtn.addEventListener('click', () => {
      windowEl.classList.add('hidden');
    });

    // Close window if clicked outside of it
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (
        !windowEl.classList.contains('hidden') && 
        !windowEl.contains(target) && 
        !trigger.contains(target)
      ) {
        windowEl.classList.add('hidden');
      }
    });

    // Form Submit
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const prompt = input.value.trim();
      if (!prompt) return;

      input.value = '';
      handleUserQuery(prompt);
    });

    // Handle suggestions
    suggestionsContainer?.addEventListener('click', (e) => {
      const pill = (e.target as HTMLElement).closest('.suggestion-pill');
      if (pill) {
        const text = pill.textContent?.trim() || '';
        if (text) {
          handleUserQuery(text);
        }
      }
    });

    async function handleUserQuery(query: string) {
      // Append user message
      appendMessageBubble('user', query);
      chatHistory.push({ role: 'user', content: query });
      saveHistory();

      // Show typing indicator
      const typingIndicator = showTypingIndicator();
      scrollToBottom();

      try {
        // Fetch response from Workers AI API
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: {
            'content-type': 'application/json'
          },
          body: JSON.stringify({ messages: chatHistory })
        });

        // Hide typing indicator
        typingIndicator.remove();

        const data = await res.json() as any;

        if (res.ok && data.success) {
          const answer = data.response;
          appendMessageBubble('assistant', answer);
          chatHistory.push({ role: 'assistant', content: answer });
          saveHistory();
        } else {
          throw new Error(data.error || 'Failed to generate response.');
        }

      } catch (err: any) {
        typingIndicator.remove();
        appendMessageBubble('assistant', err.message || 'Sorry, I encountered an issue connecting to my neural network. Please try again later.');
        console.error('Chat error:', err);
      } finally {
        scrollToBottom();
      }
    }

    function parseMarkdown(text: string): string {
      // 1. Escape HTML first to prevent XSS
      let html = text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');

      // 2. Fenced Code Blocks (```lang\ncode```)
      html = html.replace(/```(\w*)\n([\s\S]*?)```/g, (_, lang, code) => {
        const language = lang ? lang.trim() : 'code';
        return `<div class="chat-code-block"><div class="chat-code-header">${language}</div><pre><code>${code.trim()}</code></pre></div>`;
      });

      // 3. Headings
      html = html.replace(/^###\s+(.*)$/gm, '<h3>$1</h3>');
      html = html.replace(/^##\s+(.*)$/gm, '<h2>$1</h2>');
      html = html.replace(/^#\s+(.*)$/gm, '<h1>$1</h1>');

      // 4. Bold & Italic
      html = html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
      html = html.replace(/__(.*?)__/g, '<strong>$1</strong>');
      html = html.replace(/\*(.*?)\*/g, '<em>$1</em>');
      html = html.replace(/_(.*?)_/g, '<em>$1</em>');

      // 5. Inline Code
      html = html.replace(/`(.*?)`/g, '<code>$1</code>');

      // 6. Links ([label](url))
      html = html.replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" class="chat-link" target="_blank" rel="noopener noreferrer">$1</a>');

      // 7. Handle lists line-by-line
      const lines = html.split('\n');
      let inUnordered = false;
      let inOrdered = false;
      const processed = [];

      for (let i = 0; i < lines.length; i++) {
        const line = lines[i];
        const ulMatch = line.match(/^[\*\-]\s+(.*)$/);
        const olMatch = line.match(/^(\d+)\.\s+(.*)$/);

        if (ulMatch) {
          if (inOrdered) {
            processed.push('</ol>');
            inOrdered = false;
          }
          if (!inUnordered) {
            processed.push('<ul class="chat-list unordered">');
            inUnordered = true;
          }
          processed.push(`<li>${ulMatch[1]}</li>`);
        } else if (olMatch) {
          if (inUnordered) {
            processed.push('</ul>');
            inUnordered = false;
          }
          if (!inOrdered) {
            processed.push('<ol class="chat-list ordered">');
            inOrdered = true;
          }
          processed.push(`<li>${olMatch[2]}</li>`);
        } else {
          if (inUnordered) {
            processed.push('</ul>');
            inUnordered = false;
          }
          if (inOrdered) {
            processed.push('</ol>');
            inOrdered = false;
          }
          processed.push(line);
        }
      }

      if (inUnordered) processed.push('</ul>');
      if (inOrdered) processed.push('</ol>');

      // 8. Paragraph grouping
      const joined = processed.join('\n');
      const blocks = joined.split(/\n{2,}/);
      const formatted = blocks.map(block => {
        const trimmed = block.trim();
        if (!trimmed) return '';
        // If it starts with block container tag, don't wrap in <p>
        if (
          trimmed.startsWith('<ul') || 
          trimmed.startsWith('<ol') || 
          trimmed.startsWith('<h') || 
          trimmed.startsWith('<div')
        ) {
          return trimmed;
        }
        return `<p>${trimmed.replace(/\n/g, '<br />')}</p>`;
      });

      return formatted.filter(b => b).join('\n');
    }

    function appendMessageBubble(role: 'user' | 'assistant', content: string) {
      const messageDiv = document.createElement('div');
      messageDiv.className = `message ${role}`;
      
      const bubble = document.createElement('div');
      bubble.className = 'message-bubble';
      
      if (role === 'assistant') {
        bubble.innerHTML = parseMarkdown(content);
      } else {
        bubble.textContent = content;
      }

      messageDiv.appendChild(bubble);
      messagesArea!.appendChild(messageDiv);
    }

    function showTypingIndicator(): HTMLElement {
      const indicator = document.createElement('div');
      indicator.className = 'message assistant typing-container';
      
      const bubble = document.createElement('div');
      bubble.className = 'message-bubble typing-indicator';
      
      bubble.innerHTML = `
        <span class="typing-dot"></span>
        <span class="typing-dot"></span>
        <span class="typing-dot"></span>
      `;
      
      indicator.appendChild(bubble);
      messagesArea!.appendChild(indicator);
      return indicator;
    }

    function scrollToBottom() {
      messagesArea!.scrollTop = messagesArea!.scrollHeight;
    }

    function saveHistory() {
      sessionStorage.setItem('ctos_chat_history', JSON.stringify(chatHistory));
    }
  }

  // Bind to Astro View Transitions swap
  document.addEventListener('astro:page-load', initChatWidget);
</script>
