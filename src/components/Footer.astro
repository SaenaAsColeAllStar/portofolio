---
import { socials } from "../data/socials";
import { SITE_TITLE } from "../consts";

const today = new Date();
---

<footer>
	<div>
		<strong>{SITE_TITLE}</strong>
		<p>Bridging Infrastructure, AI, and Product Engineering.</p>
	</div>
	<div class="social-links">
		{socials.map((social) => <a href={social.href}>{social.label}</a>)}
	</div>
	<p class="copyright">&copy; {today.getFullYear()} CTOS. All rights reserved.</p>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border);
		color: var(--muted);
		display: grid;
		gap: 1rem;
		margin: 0 auto;
		padding: 3rem 0;
		width: min(1120px, calc(100% - 2rem));
	}

	strong {
		color: var(--text);
	}

	.social-links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.social-links a {
		color: var(--text);
		text-decoration: none;
	}

	.copyright {
		color: var(--subtle);
		font-size: 0.9rem;
	}
</style>
