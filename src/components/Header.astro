---
import HeaderLink from "./HeaderLink.astro";
import { navigationItems } from "../data/navigation";
import { SITE_TITLE } from "../consts";
import Logo from "./Logo.astro";
import SplashScreen from "./SplashScreen.astro";
---

<SplashScreen />

<header class="site-header">
	<nav aria-label="Main navigation">
		<a class="brand" href="/" aria-label={`${SITE_TITLE} home`}>
			<Logo variant="navbar" size="95px" />
		</a>
		<div class="nav-actions">
			<div class="internal-links">
				{navigationItems.map((item) => <HeaderLink href={item.href}>{item.label}</HeaderLink>)}
			</div>
			<button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme" title="Toggle light/dark mode">
				<svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
				<svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
			</button>
		</div>
	</nav>
</header>

<script>
	function initTheme() {
		const toggle = document.getElementById('theme-toggle');
		const root = document.documentElement;

		function getTheme(): string {
			return localStorage.getItem('theme') || 'dark';
		}

		function setTheme(theme: string) {
			root.setAttribute('data-theme', theme);
			localStorage.setItem('theme', theme);
		}

		// Initialize
		setTheme(getTheme());

		toggle?.addEventListener('click', () => {
			const current = getTheme();
			setTheme(current === 'dark' ? 'light' : 'dark');
		});
	}

	document.addEventListener('astro:page-load', initTheme);
</script>

<style>
	.site-header {
		backdrop-filter: blur(18px);
		background: var(--header-bg);
		border-bottom: 1px solid var(--border);
		position: sticky;
		top: 0;
		z-index: 10;
	}

	nav {
		align-items: center;
		display: flex;
		gap: 1rem;
		justify-content: space-between;
		margin: 0 auto;
		min-height: 72px;
		width: min(1120px, calc(100% - 2rem));
	}

	.brand {
		align-items: center;
		display: inline-flex;
		font-weight: 700;
		gap: 0.75rem;
		text-decoration: none;
	}

	.brand-mark {
		align-items: center;
		background: linear-gradient(135deg, var(--accent), var(--accent-strong));
		border-radius: 0.8rem;
		display: inline-flex;
		height: 2.1rem;
		justify-content: center;
		letter-spacing: -0.08em;
		width: 2.1rem;
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.internal-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem;
		justify-content: flex-end;
	}

	.internal-links a {
		border-radius: 999px;
		color: var(--muted);
		font-size: 0.92rem;
		padding: 0.45rem 0.7rem;
		text-decoration: none;
	}

	.internal-links a:hover,
	.internal-links a.active {
		background: rgba(255, 255, 255, 0.08);
		color: var(--text);
	}

	.theme-toggle {
		align-items: center;
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid var(--border);
		border-radius: 999px;
		color: var(--muted);
		cursor: pointer;
		display: inline-flex;
		height: 2.2rem;
		justify-content: center;
		transition: color 0.2s, background 0.2s;
		width: 2.2rem;
		flex-shrink: 0;
	}

	.theme-toggle:hover {
		background: rgba(255, 255, 255, 0.12);
		color: var(--text);
	}

	/* Dark mode: show sun, hide moon */
	:global([data-theme="dark"]) .icon-sun { display: block; }
	:global([data-theme="dark"]) .icon-moon { display: none; }

	/* Light mode: show moon, hide sun */
	:global([data-theme="light"]) .icon-sun { display: none; }
	:global([data-theme="light"]) .icon-moon { display: block; }

	/* Default (no JS yet) */
	.icon-moon { display: none; }

	@media (max-width: 760px) {
		nav {
			align-items: flex-start;
			flex-direction: column;
			padding: 1rem 0;
		}

		.internal-links {
			justify-content: flex-start;
		}
	}
</style>
