---
// PageView.astro - Dynamic page view counter badge
---

<div class="page-views-badge hidden" id="page-views-container">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="views-icon">
    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
    <circle cx="12" cy="12" r="3"></circle>
  </svg>
  <span id="page-views-count">0</span> views
</div>

<style>
  .page-views-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border);
    padding: 0.3rem 0.75rem;
    border-radius: 99px;
    font-weight: 500;
    width: fit-content;
    transition: opacity 0.3s ease;
  }
  .page-views-badge.hidden {
    opacity: 0;
    pointer-events: none;
  }
  .views-icon {
    opacity: 0.7;
  }
</style>

<script>
  function initPageViews() {
    const container = document.getElementById('page-views-container');
    const countSpan = document.getElementById('page-views-count');
    if (!container || !countSpan) return;

    // Normalize path to exclude trailing slashes for consistency
    let currentPath = window.location.pathname;
    if (currentPath.length > 1 && currentPath.endsWith('/')) {
      currentPath = currentPath.slice(0, -1);
    }

    // Call API to increment and get count
    fetch('/api/views', {
      method: 'POST',
      headers: {
        'content-type': 'application/json'
      },
      body: JSON.stringify({ path: currentPath })
    })
      .then(res => res.json())
      .then((data: any) => {
        if (data && typeof data.count === 'number') {
          countSpan.textContent = data.count.toLocaleString();
          container.classList.remove('hidden');
        }
      })
      .catch(err => {
        console.error('Failed to update page views:', err);
      });
  }

  // Handle initialization on initial load and view transition swap
  document.addEventListener('astro:page-load', initPageViews);
</script>
