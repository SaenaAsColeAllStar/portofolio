---
import { getCollection } from "astro:content";
import FormattedDate from "../ui/FormattedDate.astro";
import { useTranslations, getLocalizedUrl } from "../../utils/i18n";

interface Props {
  locale: 'en' | 'id';
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const certificates = (await getCollection("certificates"))
	.filter((cert) => cert.id.startsWith(locale + "/"))
	.sort((a, b) => b.data.issuedAt.valueOf() - a.data.issuedAt.valueOf())
	.slice(0, 3);

function getCleanSlug(id: string) {
	const parts = id.split('/');
	return parts.slice(1).join('/');
}
---

{certificates.length > 0 && (
	<section class="section">
		<div class="section-heading">
			<div>
				<p class="eyebrow">{locale === 'en' ? 'Certificate Vault' : 'Kubah Sertifikat'}</p>
				<h2>{t("home.certsHeadline")}</h2>
			</div>
			<a href={getLocalizedUrl("/certificates", locale)}>{t("btn.viewAll")}</a>
		</div>
		<div class="grid grid-3">
			{certificates.map((cert) => (
				<article class="card cert-preview-card">
					<h3><a href={getLocalizedUrl(`/certificates/${getCleanSlug(cert.id)}`, locale)}>{cert.data.title}</a></h3>
					<p class="cert-issuer">{cert.data.issuer}</p>
					<p class="cert-date"><FormattedDate date={cert.data.issuedAt} /></p>
				</article>
			))}
		</div>
	</section>
)}

<style>
	.section-heading {
		margin-top: 1.5rem;
		align-items: center;
		display: flex;
		gap: 1.5rem;
		justify-content: space-between;
	}
	.section-heading a {
		text-decoration: none;
	}
	.cert-preview-card {
		display: grid;
		gap: 1rem;
	}
	.cert-preview-card a {
		text-decoration: none;
	}
	.cert-issuer {
		color: var(--accent);
		font-weight: 500;
	}
	.cert-date {
		font-size: 0.9rem;
		opacity: 0.7;
	}
	@media (max-width: 860px) {
		.section-heading {
			align-items: stretch;
			flex-direction: column;
		}
	}
</style>
