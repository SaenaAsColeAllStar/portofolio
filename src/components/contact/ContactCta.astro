---
import { useTranslations, getLocalizedUrl } from "../../utils/i18n";

interface Props {
  locale: 'en' | 'id';
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="section cta card">
	<div>
		<p class="eyebrow">{locale === 'en' ? 'Resume & Contact' : 'Resume & Kontak'}</p>
		<h2>{t("home.ctaHeadline")}</h2>
		<p>{t("home.ctaBody")}</p>
	</div>
	<div class="button-row">
		<a class="button" href={getLocalizedUrl("/resume", locale)} data-track="footer-resume-cta">{t("btn.resume")}</a>
		<a class="button secondary" href={getLocalizedUrl("/contact", locale)} data-track="footer-contact-cta">{t("btn.contact")}</a>
	</div>
</section>

<style>
	.cta {
		align-items: center;
		display: flex;
		gap: 1.5rem;
		justify-content: space-between;
	}
	@media (max-width: 860px) {
		.cta {
			align-items: stretch;
			flex-direction: column;
		}
	}
</style>
