---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { positioning } from '../../data/positioning';
import { socials } from '../../data/socials';

interface Props {
	title: string;
	description: string;
	image?: string;
	extraSchemas?: Record<string, any>[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = '/blog-placeholder-1.jpg', extraSchemas = [] } = Astro.props;

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Saepul Husna",
	"alternateName": "CTOS",
	"jobTitle": positioning.title,
	"url": Astro.site?.toString() || "https://ctos.web.id",
	"image": new URL(image, Astro.url).toString(),
	"sameAs": socials.map(s => s.href).filter(href => !href.startsWith('mailto:')),
	"description": positioning.recruiterSummary,
	"knowsAbout": [
		"System Architecture",
		"Cloud Infrastructure",
		"Automation & DevOps",
		"AI Workflows & LLM Integration",
		"Product Engineering",
		"PostgreSQL",
		"Astro",
		"Cloudflare Workers"
	]
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "CTOS Portfolio",
	"alternateName": "Saepul Husna (CTOS) Professional Portfolio",
	"url": Astro.site?.toString() || "https://ctos.web.id",
	"potentialAction": {
		"@type": "SearchAction",
		"target": {
			"@type": "EntryPoint",
			"urlTemplate": `${Astro.site?.toString() || "https://ctos.web.id"}/?search={search_term_string}`
		},
		"query-input": "required name=search_term_string"
	}
};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="keywords" content="Saepul Husna, CTOS, Digital Systems Architect, System Architecture, Infrastructure Engineer, DevOps, Automation, Cloudflare Workers, Astro portfolio, PostgreSQL, AI Workflows" />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />
<meta property="og:locale" content="en_US" />
<meta property="og:site_name" content="Saepul Husna (CTOS) Portfolio" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />

<!-- Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
{extraSchemas && extraSchemas.map((schema) => (
	<script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}

<ClientRouter />

<!-- Theme and splash initialization script to prevent flash -->
<script is:inline>
	(function() {
		const theme = localStorage.getItem('theme') || 'dark';
		document.documentElement.setAttribute('data-theme', theme);

		if (sessionStorage.getItem('ctos-splash-played')) {
			document.documentElement.classList.add('ctos-splash-played');
		}
	})();
</script>

<!-- Animated favicon loader for Chrome/Safari support -->
<script>
	function initAnimatedFavicon() {
		const link = document.querySelector("link[rel='icon']") as HTMLLinkElement;
		if (!link) return;

		// Clean up existing instance if any to prevent leaks during view transitions
		if ((window as any).__cleanupFavicon) {
			(window as any).__cleanupFavicon();
		}

		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		let currentRy = 6;
		let currentXOffset = 0;
		let currentOpacity = 1;
		const pupilR = 2;

		function getTheme() {
			return document.documentElement.getAttribute('data-theme') === 'dark' || 
				(!document.documentElement.getAttribute('data-theme') && window.matchMedia('(prefers-color-scheme: dark)').matches);
		}

		function updateFavicon() {
			const isDark = getTheme();
			const accent = isDark ? '#4f8cff' : '#2563eb';
			const surface = isDark ? '#121a2c' : '#ffffff';

			const svg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="none">
				<ellipse cx="10" cy="16" rx="6" ry="${currentRy.toFixed(2)}" fill="${surface}" stroke="${accent}" stroke-width="2.5" />
				<ellipse cx="22" cy="16" rx="6" ry="${currentRy.toFixed(2)}" fill="${surface}" stroke="${accent}" stroke-width="2.5" />
				<circle cx="${(10 + currentXOffset).toFixed(2)}" cy="16" r="${pupilR}" fill="${accent}" opacity="${currentOpacity.toFixed(2)}" />
				<circle cx="${(22 + currentXOffset).toFixed(2)}" cy="16" r="${pupilR}" fill="${accent}" opacity="${currentOpacity.toFixed(2)}" />
			</svg>`;

			// Safe base64 conversion
			link.href = 'data:image/svg+xml;base64,' + btoa(svg);
		}

		let animFrameId: number | null = null;

		function animateTo(targetRy: number, targetXOffset: number, targetOpacity: number, duration: number, onComplete?: () => void) {
			if (prefersReducedMotion) {
				currentRy = targetRy;
				currentXOffset = targetXOffset;
				currentOpacity = targetOpacity;
				updateFavicon();
				if (onComplete) onComplete();
				return;
			}

			const startRy = currentRy;
			const startXOffset = currentXOffset;
			const startOpacity = currentOpacity;
			const startTime = performance.now();

			if (animFrameId) cancelAnimationFrame(animFrameId);

			function tick(now: number) {
				const elapsed = now - startTime;
				const progress = Math.min(elapsed / duration, 1);
				
				// Ease-in-out quadratic
				const ease = progress < 0.5 ? 2 * progress * progress : 1 - Math.pow(-2 * progress + 2, 2) / 2;

				currentRy = startRy + (targetRy - startRy) * ease;
				currentXOffset = startXOffset + (targetXOffset - startXOffset) * ease;
				currentOpacity = startOpacity + (targetOpacity - startOpacity) * ease;

				updateFavicon();

				if (progress < 1) {
					animFrameId = requestAnimationFrame(tick);
				} else {
					currentRy = targetRy;
					currentXOffset = targetXOffset;
					currentOpacity = targetOpacity;
					updateFavicon();
					animFrameId = null;
					if (onComplete) onComplete();
				}
			}

			animFrameId = requestAnimationFrame(tick);
		}

		let eventTimeout: any = null;
		let currentState: 'default' | 'blinking' | 'observing' | 'focus' | 'sleeping' = 'default';

		function scheduleNextEvent() {
			if (currentState === 'sleeping') return;

			if (eventTimeout) clearTimeout(eventTimeout);

			// Calm rule: 12 to 36 seconds of stillness (90% stillness ratio)
			const delay = 12000 + Math.random() * 24000;

			eventTimeout = setTimeout(() => {
				if (currentState !== 'default') return;

				const randBehavior = Math.random();
				if (randBehavior < 0.30) {
					// 30% chance to observe (saccadic glance + hesitation)
					currentState = 'observing';
					const direction = Math.random() > 0.5 ? 1.8 : -1.8;
					
					// Step 1: Look to side
					animateTo(6, direction, 1, 280, () => {
						// Step 2: Hesitate/observe for 1s
						eventTimeout = setTimeout(() => {
							// Step 3: Return to center
							animateTo(6, 0, 1, 240, () => {
								currentState = 'default';
								scheduleNextEvent();
							});
						}, 1000);
					});
				} else {
					// 70% chance to blink using Type A/B/C system
					currentState = 'blinking';
					const randBlink = Math.random();
					
					if (randBlink < 0.70) {
						// Type A: Normal Blink
						animateTo(0.5, currentXOffset, currentOpacity, 140, () => {
							animateTo(6, currentXOffset, currentOpacity, 140, () => {
								currentState = 'default';
								scheduleNextEvent();
							});
						});
					} else if (randBlink < 0.90) {
						// Type B: Fast Blink
						animateTo(0.5, currentXOffset, currentOpacity, 70, () => {
							animateTo(6, currentXOffset, currentOpacity, 75, () => {
								currentState = 'default';
								scheduleNextEvent();
							});
						});
					} else {
						// Type C: Double Blink
						animateTo(0.5, currentXOffset, currentOpacity, 110, () => {
							animateTo(6, currentXOffset, currentOpacity, 110, () => {
								eventTimeout = setTimeout(() => {
									animateTo(0.5, currentXOffset, currentOpacity, 100, () => {
										animateTo(6, currentXOffset, currentOpacity, 110, () => {
											currentState = 'default';
											scheduleNextEvent();
										});
									});
								}, 140);
							});
						});
					}
				}
			}, delay);
		}

		function handleVisibilityChange() {
			if (eventTimeout) clearTimeout(eventTimeout);
			if (animFrameId) {
				cancelAnimationFrame(animFrameId);
				animFrameId = null;
			}

			if (document.visibilityState === 'hidden') {
				currentState = 'sleeping';
				// Go to sleep (eyes closed, pupils hidden)
				animateTo(0.5, 0, 0, 300);
			} else {
				// Wake up sequence: Closed -> Half Open -> Focus -> Open
				animateTo(3, 0, 0.5, 150, () => {
					animateTo(4.5, 0, 1, 150, () => {
						// Hold focus state for 600ms
						eventTimeout = setTimeout(() => {
							animateTo(6, 0, 1, 200, () => {
								currentState = 'default';
								scheduleNextEvent();
							});
						}, 600);
					});
				});
			}
		}

		// Watch for document-level theme changes dynamically
		const observer = new MutationObserver(() => {
			updateFavicon();
		});
		observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

		document.addEventListener('visibilitychange', handleVisibilityChange);

		// Initialize State 01 (Default)
		updateFavicon();
		scheduleNextEvent();

		// Register cleanup callback to prevent multiple intervals / listeners running concurrently
		const cleanup = () => {
			if (eventTimeout) clearTimeout(eventTimeout);
			if (animFrameId) cancelAnimationFrame(animFrameId);
			observer.disconnect();
			document.removeEventListener('visibilitychange', handleVisibilityChange);
		};
		(window as any).__cleanupFavicon = cleanup;
	}

	document.addEventListener('astro:page-load', initAnimatedFavicon);
</script>

<!-- Motion Foundation Engine -->
<script>
	import { initRevealAnimations } from '../../lib/motion/reveal';
	import { initCardAnimations, initCardTilt, initCardMetaReveal } from '../../lib/motion/cards';
	import { initNavigationAnimations, initNavScrollBehavior } from '../../lib/motion/navigation';
	import { initCursorTracking } from '../../lib/motion/cursor';
	import { initHeroAnimations, initHeroTextStagger, initHeroNodePulse, initCTAMagnetic, initDynamicArrows, initSectionIndicator } from '../../lib/motion/hero';
	import { initSVGStrokeDraw, initSVGNodePulse, initGradientShift, initConnectionPulse } from '../../lib/motion/svg';
	import { initSearchAnimations } from '../../lib/motion/search';

	function initMotionEngine() {
		// M1 — Foundation
		initRevealAnimations();

		// M2 — Cards (lift + tilt + meta)
		initCardAnimations();
		initCardTilt();
		initCardMetaReveal();

		// M3 — Navigation
		initNavigationAnimations();
		initNavScrollBehavior();

		// M4 — Hero
		initHeroAnimations();
		initHeroTextStagger();
		initHeroNodePulse();
		initCTAMagnetic();
		initDynamicArrows();
		initSectionIndicator();

		// M5 — SVG
		initSVGStrokeDraw();
		initSVGNodePulse();
		initGradientShift();
		initConnectionPulse();

		// M6 — Cursor
		initCursorTracking();

		// M9 — Search
		initSearchAnimations();
	}

	document.addEventListener('astro:page-load', initMotionEngine);
</script>
