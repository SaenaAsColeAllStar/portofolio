---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { positioning } from '../../data/positioning';
import { socials } from '../../data/socials';

interface Props {
	title: string;
	description: string;
	image?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = '/blog-placeholder-1.jpg' } = Astro.props;

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Saepul Husna",
	"alternateName": "CTOS",
	"jobTitle": positioning.title,
	"url": Astro.site?.toString() || "https://ctos.web.id",
	"image": new URL(image, Astro.url).toString(),
	"sameAs": socials.map(s => s.href).filter(href => !href.startsWith('mailto:')),
	"description": positioning.recruiterSummary,
	"knowsAbout": [
		"System Architecture",
		"Cloud Infrastructure",
		"Automation & DevOps",
		"AI Workflows & LLM Integration",
		"Product Engineering",
		"PostgreSQL",
		"Astro",
		"Cloudflare Workers"
	]
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "CTOS Portfolio",
	"alternateName": "Saepul Husna (CTOS) Professional Portfolio",
	"url": Astro.site?.toString() || "https://ctos.web.id",
	"potentialAction": {
		"@type": "SearchAction",
		"target": {
			"@type": "EntryPoint",
			"urlTemplate": `${Astro.site?.toString() || "https://ctos.web.id"}/?search={search_term_string}`
		},
		"query-input": "required name=search_term_string"
	}
};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="keywords" content="Saepul Husna, CTOS, Digital Systems Architect, System Architecture, Infrastructure Engineer, DevOps, Automation, Cloudflare Workers, Astro portfolio, PostgreSQL, AI Workflows" />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />
<meta property="og:locale" content="en_US" />
<meta property="og:site_name" content="Saepul Husna (CTOS) Portfolio" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />

<!-- Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

<ClientRouter />

<!-- Theme initialization script to prevent flash -->
<script is:inline>
	(function() {
		const theme = localStorage.getItem('theme') || 'dark';
		document.documentElement.setAttribute('data-theme', theme);
	})();
</script>

<!-- Animated favicon loader for Chrome/Safari support -->
<script>
	function initAnimatedFavicon() {
		const link = document.querySelector("link[rel='icon']") as HTMLLinkElement;
		if (!link) return;

		const img = new Image();
		img.src = '/favicon.svg';

		const size = 64;
		const canvas = document.createElement('canvas');
		canvas.width = size;
		canvas.height = size;
		const ctx = canvas.getContext('2d');

		img.onload = () => {
			if (!ctx) return;

			let isAnimating = false;
			let startTime = 0;
			const animDuration = 600; // 0.6 seconds pulse duration
			const cycleInterval = 3000; // runs every 3 seconds

			function animate(timestamp: number) {
				if (!startTime) startTime = timestamp;
				const elapsed = timestamp - startTime;
				const progress = Math.min(elapsed / animDuration, 1);

				const ease = Math.sin(progress * Math.PI);
				const scale = 1 + ease * 0.12; 
				const rotate = (ease * 5 * Math.PI) / 180; 

				ctx!.clearRect(0, 0, size, size);
				ctx!.save();
				ctx!.translate(size / 2, size / 2);
				ctx!.rotate(rotate);
				ctx!.scale(scale, scale);
				ctx!.drawImage(img, -size / 2, -size / 2, size, size);
				ctx!.restore();

				link.href = canvas.toDataURL('image/png');

				if (progress < 1) {
					requestAnimationFrame(animate);
				} else {
					link.href = '/favicon.svg';
					isAnimating = false;
				}
			}

			setInterval(() => {
				if (isAnimating) return;
				isAnimating = true;
				startTime = 0;
				requestAnimationFrame(animate);
			}, cycleInterval);
		};
	}

	document.addEventListener('astro:page-load', initAnimatedFavicon);
</script>

<!-- Motion Foundation Engine -->
<script>
	import { initRevealAnimations } from '../../lib/motion/reveal';
	import { initCardAnimations } from '../../lib/motion/cards';
	import { initNavigationAnimations } from '../../lib/motion/navigation';
	import { initCursorTracking } from '../../lib/motion/cursor';

	function initMotionEngine() {
		initRevealAnimations();
		initCardAnimations();
		initNavigationAnimations();
		initCursorTracking();
	}

	document.addEventListener('astro:page-load', initMotionEngine);
</script>
