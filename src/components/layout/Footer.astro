---
import { socials } from "../../data/socials";
import { SITE_TITLE } from "../../consts";
import CommandPalette from "../command/CommandPalette.astro";
import PageView from "../analytics/PageView.astro";
import ChatWidget from "../contact/ChatWidget.astro";

const today = new Date();
---

<footer class="footer-reveal">
	<div data-animate="fade-up">
		<strong>{SITE_TITLE}</strong>
		<p>Bridging Infrastructure, AI, and Product Engineering.</p>
		<div style="margin-top: 0.8rem;">
			<PageView />
		</div>
	</div>
	<div class="social-links" data-animate="stagger" data-animate-stagger="60" data-animate-children="fade-up" data-animate-duration="400">
		{socials.map((social) => <a href={social.href} data-track={`social-${social.label.toLowerCase()}`} data-cursor="explore">{social.label}</a>)}
	</div>
	<p class="copyright" data-animate="fade-in" data-animate-delay="200">&copy; {today.getFullYear()} CTOS. All rights reserved. <span class="cmd-hint">Press <kbd>CMD</kbd>+<kbd>K</kbd> or <kbd>CTRL</kbd>+<kbd>K</kbd> to search.</span> · <a href="/analytics" class="privacy-link">System Analytics</a> · <a href="/privacy" class="privacy-link">Privacy Policy</a></p>
</footer>

<CommandPalette />
<ChatWidget />

<script>
	import { initAnalytics } from "../../utils/analytics";
	document.addEventListener("astro:page-load", initAnalytics);
</script>

<style>
	footer {
		border-top: 1px solid var(--border);
		color: var(--muted);
		display: grid;
		gap: 1rem;
		margin: 0 auto;
		padding: 3rem 0;
		width: min(1120px, calc(100% - 2rem));
	}

	strong {
		color: var(--text);
	}

	.social-links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.social-links a {
		color: var(--text);
		text-decoration: none;
	}

	.copyright {
		color: var(--subtle);
		font-size: 0.9rem;
	}
	
	.privacy-link {
		color: var(--subtle);
		text-decoration: underline;
		transition: color 0.2s;
	}
	
	.privacy-link:hover {
		color: var(--text);
	}
	
	.cmd-hint {
		margin-left: 1rem;
		opacity: 0.6;
	}
	
	kbd {
		background: rgba(255, 255, 255, 0.1);
		padding: 0.15rem 0.35rem;
		border-radius: 4px;
		font-family: monospace;
		font-size: 0.85em;
		border: 1px solid rgba(255, 255, 255, 0.2);
	}
	
	@media (max-width: 768px) {
		footer {
			padding-bottom: 7.5rem;
		}
		.cmd-hint {
			display: none;
		}
	}
</style>
