---
// Section.astro - Standard Section spacing wrapper
interface Props {
	id?: string;
	className?: string;
}
const { id, className = "" } = Astro.props;
---
<section id={id} class={`section ${className}`}>
	<slot />
</section>

<style>
	.section {
		padding: var(--spacing-xxl, 4rem) 0;
	}
	
	@media (max-width: 768px) {
		.section {
			padding: var(--spacing-xl, 2rem) 0;
		}
	}
</style>
