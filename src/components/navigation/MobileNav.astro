---
// MobileNav.astro - Bottom tab-bar navigation for mobile screens
import { useTranslations } from "../../utils/i18n";
const locale = (Astro.currentLocale || 'en') as 'en' | 'id';
const t = useTranslations(locale);

const homeHref = locale === 'en' ? '/' : '/id';
const aboutHref = locale === 'en' ? '/about' : '/id/about';
const projectsHref = locale === 'en' ? '/projects' : '/id/projects';
const notesHref = locale === 'en' ? '/notes' : '/id/notes';
---

<nav class="mobile-bottom-nav" aria-label="Mobile navigation">
	<a href={homeHref} class="nav-item" aria-label={t("nav.home")}>
		<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
			<polyline points="9 22 9 12 15 12 15 22"></polyline>
		</svg>
		<span>{t("nav.home")}</span>
	</a>
	<a href={aboutHref} class="nav-item" aria-label={t("nav.about")}>
		<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
			<circle cx="12" cy="7" r="4"></circle>
		</svg>
		<span>{t("nav.about")}</span>
	</a>
	<a href={projectsHref} class="nav-item" aria-label={t("nav.projects")}>
		<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<polyline points="16 18 22 12 16 6"></polyline>
			<polyline points="8 6 2 12 8 18"></polyline>
		</svg>
		<span>{t("nav.projects")}</span>
	</a>
	<a href={notesHref} class="nav-item" aria-label={t("nav.notes")}>
		<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"></path>
			<path d="M6 6h10"></path>
			<path d="M6 10h10"></path>
		</svg>
		<span>{t("nav.notes")}</span>
	</a>
	<button id="mobile-search-trigger" class="nav-item btn-trigger" aria-label="Search">
		<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="11" cy="11" r="8"></circle>
			<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
		</svg>
		<span>{locale === 'en' ? 'Search' : 'Cari'}</span>
	</button>
</nav>

<script>
	function initMobileSearch() {
		const trigger = document.getElementById('mobile-search-trigger');
		trigger?.addEventListener('click', () => {
			const palette = document.getElementById('command-palette');
			if (palette) {
				palette.classList.remove('hidden');
				const input = document.getElementById('command-input') as HTMLInputElement | null;
				input?.focus();
			}
		});
	}
	document.addEventListener('astro:page-load', initMobileSearch);
</script>

<style>
	.mobile-bottom-nav {
		position: fixed;
		bottom: 0;
		left: 0;
		right: 0;
		height: 64px;
		background: rgba(18, 26, 44, 0.85);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
		border-top: 1px solid var(--border);
		display: flex;
		justify-content: space-around;
		align-items: center;
		z-index: 90;
		padding: 0.2rem 0.5rem;
		box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.25);
	}

	:global([data-theme="light"]) .mobile-bottom-nav {
		background: rgba(255, 255, 255, 0.85);
		box-shadow: 0 -8px 32px rgba(15, 23, 42, 0.05);
	}

	.nav-item {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		color: var(--muted);
		text-decoration: none;
		gap: 0.2rem;
		font-size: 0.68rem;
		font-weight: var(--font-weight-medium);
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 0.4rem 0.6rem;
		border-radius: var(--radius-md);
		transition: color var(--duration-fast), background var(--duration-fast);
		width: 20%;
		outline: none;
	}

	.nav-item:hover,
	.nav-item:focus {
		color: var(--text);
		background: var(--hover-bg);
	}

	.nav-item svg {
		transition: transform var(--duration-fast);
	}

	.nav-item:active svg {
		transform: scale(0.9);
	}

	/* Display only on mobile screens */
	@media (min-width: 769px) {
		.mobile-bottom-nav {
			display: none;
		}
	}
</style>
