---
interface Props {
	variant?: 'navbar' | 'hero' | 'splash' | 'default';
	class?: string;
	size?: number | string;
}

const { variant = 'default', class: className = '', size = '100%' } = Astro.props;

// Generate unique IDs for SVG defs to avoid collisions when multiple logos are rendered on a single page
const uniqueId = Math.random().toString(36).substring(2, 9);
const goldGradId = `logo-gold-${uniqueId}`;
const sweepGradId = `logo-sweep-${uniqueId}`;
const shapesMaskId = `logo-shapes-mask-${uniqueId}`;
---

<div class={`ctos-logo-container ${variant} ${className}`} style={`width: ${size};`}>
	<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 290 120" fill="none" class="ctos-svg">
		<defs>
			<linearGradient id={goldGradId} x1="0%" y1="0%" x2="100%" y2="100%">
				<stop offset="0%" stop-color="#F4C46A" />
				<stop offset="50%" stop-color="#D4A54A" />
				<stop offset="100%" stop-color="#B3862E" />
			</linearGradient>
			
			<linearGradient id={sweepGradId} x1="0%" y1="0%" x2="100%" y2="0%">
				<stop offset="0%" stop-color="rgba(255, 255, 255, 0)" />
				<stop offset="30%" stop-color="rgba(255, 255, 255, 0.45)" />
				<stop offset="70%" stop-color="rgba(255, 255, 255, 0.45)" />
				<stop offset="100%" stop-color="rgba(255, 255, 255, 0)" />
			</linearGradient>

			<mask id={shapesMaskId}>
				<g fill="white">
					<!-- C Path -->
					<path d="M 85 28 L 45 28 A 32 32 0 0 0 45 92 L 85 92 L 71 78 L 45 78 A 18 18 0 0 1 45 42 L 71 42 Z" />
					<!-- T Path -->
					<path d="M 104 28 L 170 28 L 156 42 L 136 42 L 136 92 L 128 92 L 122 86 L 122 42 L 90 42 Z" />
					<!-- o Path -->
					<path d="M 200 42 A 25 25 0 1 0 200 92 A 25 25 0 1 0 200 42 M 200 56 A 11 11 0 1 1 200 78 A 11 11 0 1 1 200 56 Z" fill-rule="evenodd" />
					<!-- s Path -->
					<path d="M 244 42 L 276 42 L 276 56 L 258 56 L 236 78 L 262 78 L 276 92 L 230 92 L 230 78 L 248 78 L 270 56 L 244 56 L 230 56 Z" />
				</g>
			</mask>
		</defs>

		<!-- C Connection Ring Pulse (Animasi 3) -->
		<circle class="ctos-c-ring" cx="45" cy="60" r="32" stroke="#D4A54A" stroke-width="2" fill="none" opacity="0" />

		<!-- Letter C -->
		<path class="ctos-c" d="M 85 28 L 45 28 A 32 32 0 0 0 45 92 L 85 92 L 71 78 L 45 78 A 18 18 0 0 1 45 42 L 71 42 Z" fill={`url(#${goldGradId})`} />

		<!-- Letter T -->
		<path class="ctos-t" d="M 104 28 L 170 28 L 156 42 L 136 42 L 136 92 L 128 92 L 122 86 L 122 42 L 90 42 Z" fill="currentColor" />

		<!-- Letter o -->
		<path class="ctos-o" d="M 200 42 A 25 25 0 1 0 200 92 A 25 25 0 1 0 200 42 M 200 56 A 11 11 0 1 1 200 78 A 11 11 0 1 1 200 56 Z" fill-rule="evenodd" fill="currentColor" />

		<!-- Letter s -->
		<path class="ctos-s" d="M 244 42 L 276 42 L 276 56 L 258 56 L 236 78 L 262 78 L 276 92 L 230 92 L 230 78 L 248 78 L 270 56 L 244 56 L 230 56 Z" fill="currentColor" />

		<!-- Animated Sweep Rect (masked to shapes) -->
		<rect class="ctos-sweep-rect" x="-150" y="0" width="100" height="120" fill={`url(#${sweepGradId})`} mask={`url(#${shapesMaskId})`} transform="skewX(-20)" />
	</svg>
</div>

<style>
	.ctos-logo-container {
		display: inline-block;
		height: auto;
		vertical-align: middle;
	}

	.ctos-svg {
		display: block;
		width: 100%;
		height: 100%;
		overflow: visible;
	}

	/* Base colors */
	.ctos-t, .ctos-o, .ctos-s {
		color: var(--text);
		transition: color 0.3s ease;
	}

	/* ---------------- ANIMATIONS ---------------- */

	/* Sweep Light keyframe */
	@keyframes logoSweep {
		0% {
			transform: translateX(-150px) skewX(-20deg);
		}
		35%, 100% {
			transform: translateX(450px) skewX(-20deg);
		}
	}

	/* Breathing keyframe */
	@keyframes logoBreath {
		0%, 100% {
			transform: scale(1);
			filter: brightness(1);
		}
		50% {
			transform: scale(1.02);
			filter: brightness(1.1);
		}
	}

	/* Connection Ring keyframe */
	@keyframes pulseRing {
		0% {
			transform: scale(0.8);
			opacity: 0.8;
		}
		100% {
			transform: scale(1.4);
			opacity: 0;
		}
	}

	/* ---------------- VARIANTS ---------------- */

	/* --- HERO VARIANT --- */
	.hero.ctos-logo-container {
		animation: logoBreath 4s ease-in-out infinite;
	}
	.hero .ctos-sweep-rect {
		animation: logoSweep 4s ease-in-out infinite;
	}

	/* --- NAVBAR VARIANT --- */
	/* Navbar has no continuous animation, only sweep on hover */
	.navbar.ctos-logo-container:hover .ctos-sweep-rect {
		animation: logoSweep 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	/* --- SPLASH INTRO ANIMATIONS (Page Load) --- */
	@keyframes fadeInC {
		0% { opacity: 0; transform: scale(0.8); }
		100% { opacity: 1; transform: scale(1); }
	}
	@keyframes slideInT {
		0% { opacity: 0; transform: translateX(20px); }
		100% { opacity: 1; transform: translateX(0); }
	}
	@keyframes drawO {
		0% { opacity: 0; transform: scale(0.5) rotate(-45deg); }
		100% { opacity: 1; transform: scale(1) rotate(0deg); }
	}
	@keyframes assembleS {
		0% { opacity: 0; transform: translateY(10px); }
		100% { opacity: 1; transform: translateY(0); }
	}

	.splash .ctos-c {
		transform-origin: 45px 60px;
		animation: fadeInC 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
	}

	.splash .ctos-c-ring {
		transform-origin: 45px 60px;
		animation: pulseRing 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		animation-delay: 0.3s;
	}

	.splash .ctos-t {
		opacity: 0;
		animation: slideInT 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		animation-delay: 0.4s;
	}

	.splash .ctos-o {
		opacity: 0;
		transform-origin: 200px 67px;
		animation: drawO 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
		animation-delay: 0.8s;
	}

	.splash .ctos-s {
		opacity: 0;
		transform-origin: 253px 67px;
		animation: assembleS 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		animation-delay: 1.2s;
	}

	.splash .ctos-sweep-rect {
		animation: logoSweep 1.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		animation-delay: 1.6s;
	}
</style>
