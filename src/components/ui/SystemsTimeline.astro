---
// SystemsTimeline.astro - Displays a vertical timeline of built systems over time
interface Props {
  locale: "en" | "id";
}

const { locale } = Astro.props;

interface TimelineItem {
  year: string;
  title: string;
  subtitle: string;
  description: string;
  details: string[];
}

const timelineData: Record<"en" | "id", TimelineItem[]> = {
  en: [
    {
      year: "2022",
      title: "Computer-Based Testing System",
      subtitle: "SMK Teknovo",
      description: "Consolidated learning operations and computer-based exam suites for high student volumes.",
      details: ["High concurrency (1,000+ students)", "Local-first offline state resilience", "Astro + Cloudflare Workers edge architecture"]
    },
    {
      year: "2023",
      title: "Virtualization & Home-Lab Infrastructure",
      subtitle: "Private Systems",
      description: "Orchestrated dedicated bare-metal servers using type-1 hypervisors and virtual networks.",
      details: ["Proxmox VE virtualization", "Docker VM cluster orchestrations", "Outbound Cloudflare Tunnels (Zero Trust)"]
    },
    {
      year: "2024",
      title: "Edge-Native API Topologies",
      subtitle: "Distributed Platforms",
      description: "Designed globally distributed serverless microservices with pooled database access.",
      details: ["Cloudflare Workers & Pages deployment", "Hyperdrive real-time connection pooling", "PostgreSQL database tiering"]
    },
    {
      year: "2025",
      title: "AI Workflow & Context Automation",
      subtitle: "Smart Agent Orchestration",
      description: "Integrated edge LLMs and vector search indexers into autonomous helper applications.",
      details: ["Workers AI (Llama 3.1) integration", "Retrieval-Augmented Generation (RAG)", "Autonomous context-filtered pipelines"]
    },
    {
      year: "2026",
      title: "CTOS Systems Platform",
      subtitle: "Authority Showcase",
      description: "Consolidated professional portfolio and administrative dashboards into a production-grade system.",
      details: ["Observed telemetry & DB latency monitoring", "Admin guestbook and rate limiting filters", "Liquid physics mobile navigation capsule"]
    }
  ],
  id: [
    {
      year: "2022",
      title: "Sistem Ujian Berbasis Komputer",
      subtitle: "SMK Teknovo",
      description: "Mengonsolidasikan operasi pembelajaran dan paket ujian berbasis komputer untuk volume siswa yang tinggi.",
      details: ["Konkurensi tinggi (1.000+ siswa)", "Ketahanan status offline local-first", "Arsitektur edge Astro + Cloudflare Workers"]
    },
    {
      year: "2023",
      title: "Infrastruktur Virtualisasi & Home-Lab",
      subtitle: "Sistem Privat",
      description: "Mengatur server bare-metal khusus menggunakan hypervisor tipe-1 dan jaringan virtual.",
      details: ["Virtualisasi Proxmox VE", "Orkestrasi kluster Docker VM", "Cloudflare Tunnels keluar (Zero Trust)"]
    },
    {
      year: "2024",
      title: "Topologi API Edge-Native",
      subtitle: "Platform Terdistribusi",
      description: "Merancang layanan mikro serverless terdistribusi secara global dengan akses database ter-pooling.",
      details: ["Deployment Cloudflare Workers & Pages", "Pooling koneksi real-time Hyperdrive", "Tingkatan database PostgreSQL"]
    },
    {
      year: "2025",
      title: "Otomatisasi Alur Kerja & Konteks AI",
      subtitle: "Orkestrasi Agen Pintar",
      description: "Mengintegrasikan edge LLM dan pengindeks pencarian vektor ke dalam aplikasi asisten otonom.",
      details: ["Integrasi Workers AI (Llama 3.1)", "Retrieval-Augmented Generation (RAG)", "Pipeline terfilter konteks otonom"]
    },
    {
      year: "2026",
      title: "Platform Sistem CTOS",
      subtitle: "Showcase Otoritas",
      description: "Mengonsolidasikan portofolio profesional dan dasbor administratif ke dalam sistem kelas produksi.",
      details: ["Pemantauan telemetri terobservasi & latensi DB", "Buku tamu admin dan filter pembatasan laju", "Kapsul navigasi seluler dengan fisika cairan"]
    }
  ]
};

const items = timelineData[locale];
---

<div class="timeline-container">
  <div class="timeline-line"></div>
  
  <div class="timeline-items">
    {items.map((item, index) => (
      <div class="timeline-item" data-animate="fade-up" data-animate-delay={index * 100}>
        <div class="timeline-node-wrapper">
          <div class="timeline-node">
            <span class="node-glow"></span>
          </div>
        </div>
        
        <div class="timeline-content card" data-tilt>
          <span class="timeline-year">{item.year}</span>
          <p class="timeline-subtitle">{item.subtitle}</p>
          <h3>{item.title}</h3>
          <p class="timeline-desc">{item.description}</p>
          
          <ul class="timeline-details">
            {item.details.map((detail) => (
              <li>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="bullet-icon">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span>{detail}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .timeline-container {
    position: relative;
    max-width: 800px;
    margin: 2rem auto;
    padding: 1rem 0;
  }

  .timeline-line {
    position: absolute;
    left: 20px;
    top: 2rem;
    bottom: 2rem;
    width: 2px;
    background: linear-gradient(to bottom, var(--border) 0%, var(--accent) 50%, var(--border) 100%);
    opacity: 0.6;
  }

  .timeline-items {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .timeline-item {
    display: flex;
    position: relative;
    gap: 2rem;
  }

  .timeline-node-wrapper {
    width: 42px;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 1.5rem;
    flex-shrink: 0;
  }

  .timeline-node {
    position: relative;
    width: 14px;
    height: 14px;
    border-radius: 9999px;
    background: var(--bg);
    border: 2px solid var(--accent);
    z-index: 2;
  }

  .node-glow {
    position: absolute;
    top: -6px;
    left: -6px;
    right: -6px;
    bottom: -6px;
    border-radius: 9999px;
    background: var(--accent);
    opacity: 0.2;
    filter: blur(4px);
    animation: pulse 2.5s infinite ease-in-out;
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
      opacity: 0.2;
    }
    50% {
      transform: scale(1.3);
      opacity: 0.45;
    }
  }

  .timeline-content {
    flex: 1;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: transform var(--duration-fast, 0.2s) var(--ease-snappy, cubic-bezier(0.2, 0.8, 0.2, 1));
  }

  .timeline-content:hover {
    border-color: var(--accent);
  }

  .timeline-year {
    display: inline-block;
    align-self: flex-start;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--accent);
    background: rgba(var(--accent-rgb, 212, 175, 55), 0.1);
    padding: 0.25rem 0.65rem;
    border-radius: var(--radius-sm, 4px);
    letter-spacing: 0.05em;
  }

  .timeline-subtitle {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-weight: 600;
    margin: 0;
  }

  h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    margin: 0;
  }

  .timeline-desc {
    font-size: 0.92rem;
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
  }

  .timeline-details {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .timeline-details li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--subtle);
  }

  .bullet-icon {
    color: var(--accent);
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .timeline-container {
      padding-left: 0.5rem;
    }
    
    .timeline-item {
      gap: 1rem;
    }

    .timeline-node-wrapper {
      width: 30px;
    }

    .timeline-line {
      left: 14px;
    }
  }
</style>
