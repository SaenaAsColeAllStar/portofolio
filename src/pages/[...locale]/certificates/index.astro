---
import { getCollection } from "astro:content";
import BaseHead from "../../../components/layout/BaseHead.astro";
import Header from "../../../components/navigation/Header.astro";
import Footer from "../../../components/layout/Footer.astro";
import MobileNav from "../../../components/navigation/MobileNav.astro";
import { SITE_TITLE } from "../../../consts";
import { useTranslations } from "../../../utils/i18n";
import CertificateVault from "../../../components/certificate/CertificateVault.vue";

export async function getStaticPaths() {
	return [
		{ params: { locale: undefined } },
		{ params: { locale: "id" } }
	];
}

const locale = (Astro.params.locale || 'en') as 'en' | 'id';
const t = useTranslations(locale);

const certificates = (await getCollection("certificates"))
	.filter((cert) => cert.id.startsWith(locale + "/"))
	.sort((a, b) => b.data.issuedAt.valueOf() - a.data.issuedAt.valueOf());

const mappedCertificates = certificates.map(cert => ({
  id: cert.id,
  title: cert.data.title,
  issuer: cert.data.issuer,
  issuedAt: cert.data.issuedAt.toISOString(),
  credentialId: cert.data.credentialId,
  credentialUrl: cert.data.credentialUrl,
  skills: cert.data.skills,
  category: cert.data.category,
  body: cert.body
}));
---

<!doctype html>
<html lang={locale}>
	<head>
		<BaseHead title={`${locale === 'en' ? 'Certificates' : 'Sertifikat'} | ${SITE_TITLE}`} description="My certifications and credentials" />
	</head>
	<body>
		<Header />
		<main>
			<section class="section" data-animate="reveal">
				<p class="eyebrow">{locale === 'en' ? 'Certificate Vault' : 'Kubah Sertifikat'}</p>
				<h2>{locale === 'en' ? 'Verified Credentials and Qualifications' : 'Kredensial dan Kualifikasi Terverifikasi'}</h2>
				
        <CertificateVault client:load certificates={mappedCertificates} locale={locale} />
			</section>
		</main>
		<Footer />
		<MobileNav />
	</body>
</html>

<style>
  main {
    min-height: 80vh;
  }
</style>
