---
import { getCollection } from "astro:content";
import BaseHead from "../../components/layout/BaseHead.astro";
import Footer from "../../components/layout/Footer.astro";
import Header from "../../components/navigation/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import { proofSignals } from "../../data/metrics";
import { positioning } from "../../data/positioning";
import { capabilityMatrix } from "../../data/skills";
import { useTranslations, getLocalizedUrl } from "../../utils/i18n";
import HeroSystemMap from "../../components/HeroSystemMap.astro";
import FeaturedProjects from "../../components/project/FeaturedProjects.astro";
import NotesPreview from "../../components/notes/NotesPreview.astro";
import CertificatesPreview from "../../components/certificate/CertificatesPreview.astro";
import ContactCta from "../../components/contact/ContactCta.astro";
import ArchitecturePhilosophy from "../../components/layout/ArchitecturePhilosophy.astro";
import VisitorGlobe from "../../components/globe/VisitorGlobe.vue";
import MobileNav from "../../components/navigation/MobileNav.astro";

export async function getStaticPaths() {
	return [
		{ params: { locale: undefined } },
		{ params: { locale: "id" } }
	];
}

const locale = (Astro.params.locale || 'en') as 'en' | 'id';
const t = useTranslations(locale);

const activePositioning = positioning[locale];
const activeProofSignals = proofSignals[locale];
const activeCapabilityMatrix = capabilityMatrix[locale];

function getCleanSlug(id: string) {
	const parts = id.split('/');
	return parts.slice(1).join('/');
}

const caseStudies = (await getCollection("caseStudies")).filter((c) => c.id.startsWith(locale + "/"));
const featuredCaseStudy = caseStudies.find((study) => getCleanSlug(study.id) === "smk-teknovo-ecosystem") ?? caseStudies[0];
---

<!doctype html>
<html lang={locale}>
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-copy">
					<p class="eyebrow" data-hero-text>{activePositioning.title}</p>
					<h1 data-hero-text>{activePositioning.headline}</h1>
					<p class="lede" data-hero-text>{activePositioning.subheadline}</p>
					<div class="button-row" data-hero-text>
						<a class="button" href={getLocalizedUrl(activePositioning.primaryCta.href, locale)} data-track="hero-primary-cta" data-magnetic data-cursor="explore">{activePositioning.primaryCta.label}</a>
						<a class="button secondary" href={getLocalizedUrl(activePositioning.secondaryCta.href, locale)} data-track="hero-secondary-cta" data-magnetic data-cursor="explore">{activePositioning.secondaryCta.label}</a>
					</div>
				</div>
				<HeroSystemMap />
			</section>

			<section class="section">
				<p class="eyebrow" data-animate="fade-in">{locale === 'en' ? 'Proof Snapshot' : 'Bukti Singkat'}</p>
				<h2 data-animate="fade-up" data-animate-delay="80">{t("home.proofHeadline")}</h2>
				<div class="grid grid-3 proof-grid" data-animate="stagger" data-animate-stagger="120" data-animate-children="scale-reveal" data-animate-duration="500">
					{activeProofSignals.map((signal) => (
						<article class="card" data-tilt>
							<p class="eyebrow">{signal.label}</p>
							<h3>{signal.value}</h3>
							<p>{signal.description}</p>
						</article>
					))}
				</div>
			</section>

			{featuredCaseStudy && (
				<section class="section featured card" data-tilt data-cursor="view-case-study">
					<div>
						<p class="eyebrow">{t("home.featuredCaseStudy")}</p>
						<h2>{featuredCaseStudy.data.title}</h2>
						<p>{featuredCaseStudy.data.summary}</p>
					</div>
					<a class="button" href={getLocalizedUrl(`/case-studies/${getCleanSlug(featuredCaseStudy.id)}`, locale)}>{t("btn.readCaseStudy")}</a>
				</section>
			)}

			<section class="section">
				<p class="eyebrow" data-animate="fade-in">{locale === 'en' ? 'Capability Matrix' : 'Matriks Keahlian'}</p>
				<h2 data-animate="fade-up" data-animate-delay="60">{t("home.capabilityHeadline")}</h2>
				<div class="grid grid-3" data-animate="stagger" data-animate-stagger="90" data-animate-children="fade-up" data-animate-duration="480">
					{activeCapabilityMatrix.map((capability) => (
						<article class="card" data-tilt data-cursor="explore">
							<h3>{capability.name}</h3>
							<p>{capability.description}</p>
						</article>
					))}
				</div>
			</section>

			<FeaturedProjects locale={locale} />

			<ArchitecturePhilosophy locale={locale} />

			<NotesPreview locale={locale} />

			<CertificatesPreview locale={locale} />

			<ContactCta locale={locale} />

			<VisitorGlobe client:visible />
		</main>
		<Footer />
		<MobileNav />
	</body>
</html>

<style>
	.hero {
		align-items: center;
		display: grid;
		gap: 2rem;
		grid-template-columns: 1.15fr 0.85fr;
		min-height: calc(100vh - 72px);
		padding: 4rem 0;
	}

	.hero-copy {
		display: grid;
		gap: 1.25rem;
	}

	.proof-grid {
		margin-top: 1.5rem;
	}

	.featured {
		align-items: center;
		display: flex;
		gap: 1.5rem;
		justify-content: space-between;
	}

	@media (max-width: 860px) {
		.hero,
		.featured {
			align-items: stretch;
			grid-template-columns: 1fr;
			flex-direction: column;
		}
	}
</style>
