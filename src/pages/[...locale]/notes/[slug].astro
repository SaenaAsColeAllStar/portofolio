---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BaseHead from "../../../components/layout/BaseHead.astro";
import Header from "../../../components/navigation/Header.astro";
import MobileNav from "../../../components/navigation/MobileNav.astro";
import Footer from "../../../components/layout/Footer.astro";
import FormattedDate from "../../../components/ui/FormattedDate.astro";
import { useTranslations, getLocalizedUrl } from "../../../utils/i18n";

export async function getStaticPaths() {
	const notes = await getCollection("notes");
	return notes.map((note) => {
		const [localePrefix, ...slugParts] = note.id.split('/');
		const slug = slugParts.join('/');
		const locale = localePrefix === 'en' ? undefined : 'id';
		return {
			params: { locale, slug },
			props: note
		};
	});
}

type Props = CollectionEntry<"notes">;
const note = Astro.props;
const { Content } = await render(note);

const locale = (Astro.params.locale || 'en') as 'en' | 'id';
const t = useTranslations(locale);
---

<!doctype html>
<html lang={locale}>
	<head>
		<BaseHead title={`${note.data.title} | Notes`} description={note.data.excerpt} />
	</head>
	<body>
		<Header />
		<main>
			<article class="section note-detail">
				<a href={getLocalizedUrl("/notes", locale)} class="back-link">&larr; {locale === 'en' ? 'Back to Notes' : 'Kembali ke Catatan'}</a>
				<div class="card note-header">
					<p class="eyebrow">{note.data.category}</p>
					<h1>{note.data.title}</h1>
					<p class="date">{locale === 'en' ? 'Published:' : 'Diterbitkan:'} <FormattedDate date={note.data.publishedAt} /></p>
					
					<div class="badge-row" style="margin-top: 1.5rem;">
						{note.data.tags.map((tag) => <span class="badge">{tag}</span>)}
					</div>
				</div>
				<div class="prose">
					<Content />
				</div>
			</article>
		</main>
		<Footer />
		<MobileNav />
	</body>
</html>

<style>
	.note-detail {
		max-width: 800px;
	}
	.back-link {
		display: inline-block;
		margin-bottom: 2rem;
		text-decoration: none;
		opacity: 0.8;
	}
	.back-link:hover {
		opacity: 1;
	}
	.note-header {
		margin-bottom: 2rem;
	}
	.note-header h1 {
		margin: 0.5rem 0;
	}
	.date {
		margin: 0.25rem 0;
		opacity: 0.8;
	}
	.prose {
		margin-top: 2rem;
	}
</style>
