---
import { getCollection } from "astro:content";
import BaseHead from "../../../components/BaseHead.astro";
import Footer from "../../../components/Footer.astro";
import Header from "../../../components/Header.astro";
import { SITE_TITLE } from "../../../consts";
import { useTranslations, getLocalizedUrl } from "../../../utils/i18n";

export async function getStaticPaths() {
	return [
		{ params: { locale: undefined } },
		{ params: { locale: "id" } }
	];
}

const locale = (Astro.params.locale || 'en') as 'en' | 'id';
const t = useTranslations(locale);

const projects = (await getCollection("projects")).filter((p) => p.id.startsWith(locale + "/"));
const allCategories = [...new Set(projects.map((p) => p.data.category))].sort();

function getCleanSlug(id: string) {
	const parts = id.split('/');
	return parts.slice(1).join('/');
}
---

<!doctype html>
<html lang={locale}>
	<head><BaseHead title={`${t("nav.projects")} | ${SITE_TITLE}`} description="Selected CTOS projects organized by category, role, stack, and impact." /></head>
	<body>
		<Header />
		<main>
			<section class="page-hero">
				<p class="eyebrow">{t("nav.projects")}</p>
				<h1>{locale === 'en' ? 'Systems, workflows, and product evidence.' : 'Sistem, alur kerja, dan bukti produk.'}</h1>
				<p class="lede">{locale === 'en' ? 'Projects are framed around context, role, architecture, stack, and impact rather than screenshots alone.' : 'Proyek dibingkai berdasarkan konteks, peran, arsitektur, tumpukan teknologi, dan dampak, bukan sekadar tangkapan layar saja.'}</p>
			</section>

			<section class="section filters">
				<div class="filter-controls">
					<input type="text" id="projectSearch" placeholder={locale === 'en' ? 'Search projects by keyword...' : 'Cari proyek berdasarkan kata kunci...'} />
					<select id="categoryFilter" aria-label="Filter by category">
						<option value="all">{locale === 'en' ? 'All Categories' : 'Semua Kategori'}</option>
						{allCategories.map(cat => <option value={cat}>{cat}</option>)}
					</select>
				</div>
			</section>

			<section class="grid grid-2 section" id="projectGrid">
				{projects.map((project) => (
					<article class="card project-card" data-category={project.data.category} data-title={project.data.title.toLowerCase()} data-excerpt={project.data.excerpt.toLowerCase()}>
						<p class="eyebrow">{project.data.category} · {project.data.year}</p>
						<h2><a href={getLocalizedUrl(`/projects/${getCleanSlug(project.id)}`, locale)}>{project.data.title}</a></h2>
						<p>{project.data.excerpt}</p>
						<p><strong>{locale === 'en' ? 'Role:' : 'Peran:'}</strong> {project.data.role}</p>
						{project.data.impact && <p><strong>{locale === 'en' ? 'Impact:' : 'Dampak:'}</strong> {project.data.impact}</p>}
						<div class="badge-row">
							{project.data.stack.map((item) => <span class="badge">{item}</span>)}
						</div>
					</article>
				))}
				<div id="noResults" class="hidden">{locale === 'en' ? 'No projects found matching your criteria.' : 'Tidak ada proyek yang ditemukan cocok dengan kriteria Anda.'}</div>
			</section>
		</main>
		<Footer />

		<script>
			document.addEventListener('astro:page-load', () => {
				const searchInput = document.getElementById('projectSearch') as HTMLInputElement;
				const categorySelect = document.getElementById('categoryFilter') as HTMLSelectElement;
				const projectCards = document.querySelectorAll('.project-card');
				const noResults = document.getElementById('noResults');

				function filterProjects() {
					const searchTerm = searchInput.value.toLowerCase();
					const selectedCategory = categorySelect.value;
					let visibleCount = 0;

					projectCards.forEach((card) => {
						const htmlCard = card as HTMLElement;
						const title = htmlCard.dataset.title || '';
						const excerpt = htmlCard.dataset.excerpt || '';
						const category = htmlCard.dataset.category || '';

						const matchesSearch = title.includes(searchTerm) || excerpt.includes(searchTerm);
						const matchesCategory = selectedCategory === 'all' || category === selectedCategory;

						if (matchesSearch && matchesCategory) {
							htmlCard.style.display = 'grid';
							visibleCount++;
						} else {
							htmlCard.style.display = 'none';
						}
					});

					if (noResults) {
						noResults.style.display = visibleCount === 0 ? 'block' : 'none';
					}
				}

				searchInput?.addEventListener('input', filterProjects);
				categorySelect?.addEventListener('change', filterProjects);
			});
		</script>
	</body>
</html>

<style>
	.filters {
		margin-bottom: 2rem;
	}
	.filter-controls {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.filter-controls input, .filter-controls select {
		padding: 0.75rem 1rem;
		border-radius: 6px;
		border: 1px solid var(--border);
		background: transparent;
		color: var(--text);
		font-family: inherit;
		min-width: 200px;
	}
	.filter-controls input:focus, .filter-controls select:focus {
		outline: 2px solid var(--text);
		outline-offset: 2px;
	}
	.filter-controls input {
		flex: 1;
	}
	.project-card {
		display: grid;
		gap: 1rem;
	}
	.project-card a {
		text-decoration: none;
	}
	.hidden {
		display: none;
		grid-column: 1 / -1;
		text-align: center;
		padding: 3rem;
		opacity: 0.7;
	}
</style>
