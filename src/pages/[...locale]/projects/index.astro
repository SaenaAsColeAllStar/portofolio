---
import { getCollection } from "astro:content";
import BaseHead from "../../../components/layout/BaseHead.astro";
import Footer from "../../../components/layout/Footer.astro";
import Header from "../../../components/navigation/Header.astro";
import MobileNav from "../../../components/navigation/MobileNav.astro";
import { SITE_TITLE } from "../../../consts";
import { useTranslations, getLocalizedUrl } from "../../../utils/i18n";
import { githubRepos } from "../../../data/github";

export async function getStaticPaths() {
	return [
		{ params: { locale: undefined } },
		{ params: { locale: "id" } }
	];
}

const locale = (Astro.params.locale || 'en') as 'en' | 'id';
const t = useTranslations(locale);

const projects = (await getCollection("projects")).filter((p) => p.id.startsWith(locale + "/"));
const allCategories = [...new Set(projects.map((p) => p.data.category))].sort();

function getCleanSlug(id: string) {
	const parts = id.split('/');
	return parts.slice(1).join('/');
}

const activeGithubRepos = githubRepos[locale];
---

<!doctype html>
<html lang={locale}>
	<head><BaseHead title={`${t("nav.projects")} | ${SITE_TITLE}`} description="Selected CTOS projects organized by category, role, stack, and impact." /></head>
	<body>
		<Header />
		<main>
			<section class="page-hero">
				<p class="eyebrow">{t("nav.projects")}</p>
				<h1>{locale === 'en' ? 'Systems, workflows, and product evidence.' : 'Sistem, alur kerja, dan bukti produk.'}</h1>
				<p class="lede">{locale === 'en' ? 'Projects are framed around context, role, architecture, stack, and impact rather than screenshots alone.' : 'Proyek dibingkai berdasarkan konteks, peran, arsitektur, tumpukan teknologi, dan dampak, bukan sekadar tangkapan layar saja.'}</p>
			</section>

			<section class="section filters">
				<div class="filter-controls">
					<input type="text" id="projectSearch" placeholder={locale === 'en' ? 'Search projects by keyword...' : 'Cari proyek berdasarkan kata kunci...'} />
					<select id="categoryFilter" aria-label="Filter by category">
						<option value="all">{locale === 'en' ? 'All Categories' : 'Semua Kategori'}</option>
						{allCategories.map(cat => <option value={cat}>{cat}</option>)}
					</select>
				</div>
			</section>

			<section class="grid grid-2 section" id="projectGrid">
				{projects.map((project) => (
					<article class="card project-card" data-category={project.data.category} data-title={project.data.title.toLowerCase()} data-excerpt={project.data.excerpt.toLowerCase()}>
						<p class="eyebrow">{project.data.category} · {project.data.year}</p>
						<h2><a href={getLocalizedUrl(`/projects/${getCleanSlug(project.id)}`, locale)}>{project.data.title}</a></h2>
						<p>{project.data.excerpt}</p>
						<p><strong>{locale === 'en' ? 'Role:' : 'Peran:'}</strong> {project.data.role}</p>
						{project.data.impact && <p><strong>{locale === 'en' ? 'Impact:' : 'Dampak:'}</strong> {project.data.impact}</p>}
						<div class="badge-row">
							{project.data.stack.map((item) => <span class="badge">{item}</span>)}
						</div>
					</article>
				))}
				<div id="noResults" class="hidden">{locale === 'en' ? 'No projects found matching your criteria.' : 'Tidak ada proyek yang ditemukan cocok dengan kriteria Anda.'}</div>
			</section>

			<section class="section github-section">
				<p class="eyebrow">{locale === 'en' ? 'Open Source' : 'Sumber Terbuka'}</p>
				<h2>{locale === 'en' ? 'Featured Repositories' : 'Repositori Unggulan'}</h2>
				<p class="lede" style="margin-bottom: 2rem;">
					{locale === 'en' 
						? 'Explore the architecture, documentation, and codebase of featured systems and flagship components.' 
						: 'Jelajahi arsitektur, dokumentasi, dan kode sumber dari sistem unggulan dan komponen utama.'}
				</p>
				<div class="grid grid-2">
					{activeGithubRepos.map((repo) => (
						<article class="card repo-card" data-tilt data-cursor="explore">
							<div class="repo-header">
								<span class="badge">{repo.language}</span>
								<span class="repo-role">{repo.role}</span>
							</div>
							<h3 style="margin-bottom: 0.5rem; font-size: 1.5rem;">{repo.name}</h3>
							<p style="margin-bottom: 1.5rem;">{repo.description}</p>
							<div class="repo-meta">
								<span class="repo-stat">★ {repo.stars}</span>
								<span class="repo-stat">⑂ {repo.forks}</span>
								<a class="button secondary repo-link" href={repo.url} target="_blank" rel="noopener noreferrer" data-track={`github-repo-${repo.name}`}>
									{locale === 'en' ? 'View Repo' : 'Lihat Repo'}
								</a>
							</div>
						</article>
					))}
				</div>
				<div class="github-profile-cta" style="margin-top: 3rem; text-align: center;">
					<a class="button" href="https://github.com/SaenaAsColeAllStar" target="_blank" rel="noopener noreferrer" data-track="github-profile-click">
						{locale === 'en' ? 'Explore More on GitHub' : 'Jelajahi Lebih Banyak di GitHub'}
					</a>
				</div>
			</section>
		</main>
		<Footer />
		<MobileNav />

		<script>
			document.addEventListener('astro:page-load', () => {
				const searchInput = document.getElementById('projectSearch') as HTMLInputElement;
				const categorySelect = document.getElementById('categoryFilter') as HTMLSelectElement;
				const projectCards = document.querySelectorAll('.project-card');
				const noResults = document.getElementById('noResults');

				function filterProjects() {
					const searchTerm = searchInput.value.toLowerCase();
					const selectedCategory = categorySelect.value;
					let visibleCount = 0;

					projectCards.forEach((card) => {
						const htmlCard = card as HTMLElement;
						const title = htmlCard.dataset.title || '';
						const excerpt = htmlCard.dataset.excerpt || '';
						const category = htmlCard.dataset.category || '';

						const matchesSearch = title.includes(searchTerm) || excerpt.includes(searchTerm);
						const matchesCategory = selectedCategory === 'all' || category === selectedCategory;

						if (matchesSearch && matchesCategory) {
							htmlCard.style.display = 'grid';
							visibleCount++;
						} else {
							htmlCard.style.display = 'none';
						}
					});

					if (noResults) {
						noResults.style.display = visibleCount === 0 ? 'block' : 'none';
					}
				}

				searchInput?.addEventListener('input', filterProjects);
				categorySelect?.addEventListener('change', filterProjects);
			});
		</script>
	</body>
</html>

<style>
	.filters {
		margin-bottom: 2rem;
	}
	.filter-controls {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.filter-controls input, .filter-controls select {
		padding: 0.75rem 1rem;
		border-radius: 6px;
		border: 1px solid var(--border);
		background: transparent;
		color: var(--text);
		font-family: inherit;
		min-width: 200px;
	}
	.filter-controls input:focus, .filter-controls select:focus {
		outline: 2px solid var(--text);
		outline-offset: 2px;
	}
	.filter-controls input {
		flex: 1;
	}
	.project-card {
		display: grid;
		gap: 1rem;
	}
	.project-card a {
		text-decoration: none;
	}
	.hidden {
		display: none;
		grid-column: 1 / -1;
		text-align: center;
		padding: 3rem;
		opacity: 0.7;
	}
	.github-section {
		border-top: 1px solid var(--border);
		margin-top: 5rem;
		padding-top: 4rem;
	}
	.repo-card {
		display: flex;
		flex-direction: column;
		min-height: 200px;
	}
	.repo-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 0.75rem;
	}
	.repo-role {
		font-size: 0.82rem;
		font-weight: 600;
		color: var(--accent);
	}
	.repo-meta {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-top: auto;
		padding-top: 1rem;
	}
	.repo-stat {
		font-size: 0.9rem;
		color: var(--muted);
	}
	.repo-link {
		margin-left: auto;
		padding: 0.5rem 1.25rem;
		font-size: 0.85rem;
	}
</style>
