---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { positioning } from '../data/positioning';
import { capabilityMatrix } from '../data/skills';
import { technologies, technologyCategories } from '../data/technologies';

const groupedTech = Object.entries(technologyCategories).map(([key, label]) => ({
	category: key,
	label,
	items: technologies.filter((t) => t.category === key),
})).filter((group) => group.items.length > 0);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description={positioning.recruiterSummary} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Page Hero -->
			<section class="page-hero">
				<p class="eyebrow">About</p>
				<h1>{positioning.headline}</h1>
				<p class="lede">{positioning.subheadline}</p>
			</section>

			<!-- Professional Summary -->
			<section class="section">
				<p class="eyebrow">Professional Summary</p>
				<h2>Building systems that hold up under real conditions.</h2>
				<div class="prose summary-content">
					<p>
						I'm a {positioning.title.toLowerCase()} focused on connecting infrastructure, automation, AI workflows, and product engineering into cohesive systems. My work sits at the intersection of reliability and iteration — designing architectures that support real users, real traffic, and real constraints.
					</p>
					<p>
						Rather than chasing individual technologies, I focus on how components interact across a system. That means understanding deployment pipelines as well as user interfaces, database design as well as API contracts, and knowing when to automate a process versus when to simplify it entirely.
					</p>
					<p>
						{positioning.recruiterSummary}
					</p>
				</div>
			</section>

			<!-- Expertise Matrix -->
			<section class="section">
				<p class="eyebrow">Expertise Matrix</p>
				<h2>Core domains connected into one architecture-first practice.</h2>
				<div class="grid grid-3">
					{capabilityMatrix.map((capability) => (
						<article class="card capability-card">
							<div class="capability-icon" aria-hidden="true">
								<span>{capability.name.charAt(0)}</span>
							</div>
							<h3>{capability.name}</h3>
							<p>{capability.description}</p>
						</article>
					))}
				</div>
			</section>

			<!-- Philosophy / Approach -->
			<section class="section">
				<p class="eyebrow">Philosophy</p>
				<h2>How I approach engineering work.</h2>
				<div class="grid grid-2">
					<article class="card">
						<h3>Systems over stacks</h3>
						<p>Technology choices follow architecture decisions, not the other way around. I evaluate tools by how well they serve the system's constraints — not by popularity or novelty.</p>
					</article>
					<article class="card">
						<h3>Reliability as a feature</h3>
						<p>Uptime, observability, and failure recovery are designed in from the start. A system that works in development but breaks under load is an incomplete system.</p>
					</article>
					<article class="card">
						<h3>Automation with intent</h3>
						<p>I automate to eliminate toil and reduce human error — not to add complexity. Every automated workflow should be explainable, debuggable, and reversible.</p>
					</article>
					<article class="card">
						<h3>Clarity in communication</h3>
						<p>Good documentation, clean interfaces, and honest timelines matter as much as good code. Engineering is a team activity, even when you're working solo.</p>
					</article>
				</div>
			</section>

			<!-- Technology Ecosystem -->
			<section class="section">
				<p class="eyebrow">Technology Ecosystem</p>
				<h2>Tools and platforms I work with regularly.</h2>
				<div class="tech-ecosystem">
					{groupedTech.map((group) => (
						<div class="tech-group">
							<h3 class="tech-group-label">{group.label}</h3>
							<div class="badge-row">
								{group.items.map((tech) => (
									<span class="badge" title={tech.description}>{tech.name}</span>
								))}
							</div>
						</div>
					))}
				</div>
			</section>

			<!-- Contact CTA -->
			<section class="section cta card">
				<div>
					<p class="eyebrow">Get in Touch</p>
					<h2>Interested in working together?</h2>
					<p>I'm open to discussing infrastructure, automation, AI integration, and product engineering opportunities.</p>
				</div>
				<div class="button-row">
					<a class="button" href="/contact" data-track="about-contact-cta">Contact</a>
					<a class="button secondary" href="/resume" data-track="about-resume-cta">View Resume</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.summary-content {
		max-width: 72ch;
	}

	.summary-content p {
		color: var(--muted);
		line-height: 1.75;
	}

	.summary-content p + p {
		margin-top: 1rem;
	}

	.capability-card {
		display: grid;
		gap: 0.75rem;
	}

	.capability-icon {
		width: 2.5rem;
		height: 2.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 8px;
		background: var(--surface-elevated);
		border: 1px solid var(--border);
		font-weight: 700;
		font-size: 1rem;
		color: var(--accent);
	}

	.tech-ecosystem {
		display: grid;
		gap: 2rem;
		margin-top: 1.5rem;
	}

	.tech-group {
		display: grid;
		gap: 0.75rem;
	}

	.tech-group-label {
		font-size: 0.875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--subtle);
	}

	.cta {
		align-items: center;
		display: flex;
		gap: 1.5rem;
		justify-content: space-between;
	}

	@media (max-width: 860px) {
		.cta {
			align-items: stretch;
			flex-direction: column;
		}
	}
</style>
