---
export const prerender = false;

import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";
import { getDb } from "../db";
import { pageViews, guestbook, contactSubmissions } from "../db/schema";
import { desc, sql } from "drizzle-orm";

let totalViews = 0;
let totalGuestbook = 0;
let totalContact = 0;
let dbLatency = 0;
let topViews: any[] = [];
let allViews: any[] = [];
let error = null;

try {
  const env = Astro.locals.runtime?.env;
  const db = getDb(env);

  // Latency test
  const start = Date.now();
  await db.execute(sql`SELECT 1`);
  dbLatency = Date.now() - start;

  // Sum total views
  const viewsSum = await db.select({ total: sql<number>`sum(count)` }).from(pageViews);
  totalViews = Number(viewsSum[0]?.total || 0);

  // Count guestbook entries
  const gbCount = await db.select({ count: sql<number>`count(*)` }).from(guestbook);
  totalGuestbook = Number(gbCount[0]?.count || 0);

  // Count contact submissions
  const contactCount = await db.select({ count: sql<number>`count(*)` }).from(contactSubmissions);
  totalContact = Number(contactCount[0]?.count || 0);

  // Fetch top 5 page views for SVG Chart
  topViews = await db.select()
    .from(pageViews)
    .orderBy(desc(pageViews.count))
    .limit(5);

  // Fetch all page views
  allViews = await db.select()
    .from(pageViews)
    .orderBy(desc(pageViews.count));

} catch (e) {
  console.error("Dashboard metrics error:", e);
  error = "Failed to load system metrics.";
}

// Chart layout constants
const maxViewCount = topViews.length > 0 ? Math.max(...topViews.map(v => v.count)) : 100;
const chartHeight = 240;
const chartWidth = 500;
const paddingLeft = 140;
const paddingRight = 50;
const barWidth = 24;
const gap = 16;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`System Analytics | ${SITE_TITLE}`} description="Real-time system stats, database metrics, and page traffic dashboard." />
  </head>
  <body>
    <Header />
    <main class="analytics-container">
      <!-- Page Hero -->
      <section class="page-hero">
        <p class="eyebrow">Observability</p>
        <h1>System Dashboard</h1>
        <p class="lede">Real-time telemetry, database health metrics, and traffic statistics from the CTOS edge node.</p>
      </section>

      {error ? (
        <section class="error-container section">
          <div class="status-card error">
            <h2>Error Fetching Metrics</h2>
            <p>{error}</p>
          </div>
        </section>
      ) : (
        <div class="dashboard-grid section">
          <!-- Left Column - Cards & Chart -->
          <div class="dashboard-main-col">
            <!-- Stats Grid -->
            <div class="stats-card-grid">
              <article class="stat-card">
                <div class="stat-header">
                  <span class="stat-label">Total Page Hits</span>
                  <svg class="stat-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                </div>
                <div class="stat-value">{totalViews.toLocaleString()}</div>
              </article>

              <article class="stat-card">
                <div class="stat-header">
                  <span class="stat-label">Guestbook Signatures</span>
                  <svg class="stat-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                </div>
                <div class="stat-value">{totalGuestbook}</div>
              </article>

              <article class="stat-card">
                <div class="stat-header">
                  <span class="stat-label">Contact Messages</span>
                  <svg class="stat-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                </div>
                <div class="stat-value">{totalContact}</div>
              </article>

              <article class="stat-card">
                <div class="stat-header">
                  <span class="stat-label">DB Latency (Aiven)</span>
                  <svg class="stat-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                </div>
                <div class="stat-value select-latency">{dbLatency} <span class="ms-label">ms</span></div>
              </article>
            </div>

            <!-- SVG Bar Chart Section -->
            <div class="chart-container-card">
              <h2>Top Routes Traffic</h2>
              <div class="svg-chart-wrapper">
                {topViews.length === 0 ? (
                  <p class="empty-chart">No traffic data available.</p>
                ) : (
                  <svg viewBox={`0 0 ${chartWidth} ${chartHeight}`} class="svg-chart">
                    <defs>
                      <linearGradient id="barGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                        <stop offset="0%" stop-color="var(--accent, #4f8cff)" stop-opacity="0.1" />
                        <stop offset="100%" stop-color="var(--accent, #4f8cff)" stop-opacity="0.9" />
                      </linearGradient>
                    </defs>

                    {topViews.map((item, index) => {
                      const y = index * (barWidth + gap) + 20;
                      // Calculate width proportion
                      const maxBarWidth = chartWidth - paddingLeft - paddingRight;
                      const width = Math.max(8, Math.round((item.count / maxViewCount) * maxBarWidth));
                      
                      return (
                        <g class="chart-group">
                          {/* Route Path Label */}
                          <text 
                            x={paddingLeft - 12} 
                            y={y + barWidth / 2 + 5} 
                            class="chart-label"
                            text-anchor="end"
                          >
                            {item.path === '/' ? '/home' : item.path}
                          </text>

                          {/* Bar Background Track */}
                          <rect 
                            x={paddingLeft} 
                            y={y} 
                            width={maxBarWidth} 
                            height={barWidth} 
                            rx="4" 
                            class="bar-track" 
                          />

                          {/* Data Bar */}
                          <rect 
                            x={paddingLeft} 
                            y={y} 
                            width={width} 
                            height={barWidth} 
                            rx="4" 
                            fill="url(#barGrad)"
                            class="bar-fill"
                          />

                          {/* Count Value Label */}
                          <text 
                            x={paddingLeft + width + 10} 
                            y={y + barWidth / 2 + 5} 
                            class="chart-value"
                          >
                            {item.count}
                          </text>
                        </g>
                      );
                    })}

                    {/* Chart Divider Axis */}
                    <line 
                      x1={paddingLeft} 
                      y1="10" 
                      x2={paddingLeft} 
                      y2={topViews.length * (barWidth + gap) + 10} 
                      class="chart-axis" 
                    />
                  </svg>
                )}
              </div>
            </div>
          </div>

          <!-- Right Column - Complete Table List -->
          <div class="dashboard-side-col">
            <div class="routes-list-card">
              <h2>Node Path Directory</h2>
              <p class="subtitle">Detailed view count across all paths.</p>

              <div class="table-wrapper">
                <table>
                  <thead>
                    <tr>
                      <th>Path</th>
                      <th align="right">Views</th>
                    </tr>
                  </thead>
                  <tbody>
                    {allViews.map((item) => (
                      <tr>
                        <td><code>{item.path}</code></td>
                        <td align="right" class="views-cell">{item.count.toLocaleString()}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      )}
    </main>
    <Footer />
  </body>
</html>

<style>
  .analytics-container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .error-container {
    padding-bottom: 6rem;
  }

  .status-card {
    padding: 2rem;
    border-radius: 12px;
    text-align: center;
  }

  .status-card.error {
    background: rgba(231, 76, 60, 0.08);
    border: 1px solid rgba(231, 76, 60, 0.25);
    color: #e74c3c;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2.5rem;
    padding-top: 1.5rem;
    padding-bottom: 6rem;
  }

  @media (max-width: 900px) {
    .dashboard-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  .dashboard-main-col {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* Stats Card Grid */
  .stats-card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 480px) {
    .stats-card-grid {
      grid-template-columns: 1fr;
    }
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 1.5rem;
    border-radius: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .stat-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .stat-label {
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .stat-icon {
    color: var(--muted);
    opacity: 0.6;
  }

  .stat-value {
    font-size: 2.2rem;
    font-weight: 750;
    color: var(--text);
    line-height: 1.1;
  }

  .ms-label {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--muted);
    margin-left: 0.2rem;
  }

  .select-latency {
    color: #2ecc71;
  }

  /* Chart Styles */
  .chart-container-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 2rem;
    border-radius: 1rem;
  }

  .chart-container-card h2 {
    font-size: 1.3rem;
    margin: 0 0 1.5rem;
    color: var(--text);
  }

  .svg-chart-wrapper {
    width: 100%;
    overflow-x: auto;
  }

  .svg-chart {
    width: 100%;
    min-width: 450px;
    height: auto;
  }

  .chart-label {
    fill: var(--muted);
    font-size: 13px;
    font-weight: 500;
    font-family: inherit;
  }

  .chart-value {
    fill: var(--text);
    font-size: 13px;
    font-weight: 600;
    font-family: inherit;
  }

  .bar-track {
    fill: rgba(255, 255, 255, 0.02);
  }

  .bar-fill {
    transition: width 0.6s ease;
  }

  .chart-axis {
    stroke: var(--border);
    stroke-width: 1.5;
  }

  .empty-chart {
    color: var(--muted);
    font-style: italic;
    text-align: center;
    padding: 2rem 0;
  }

  /* Side List Styles */
  .routes-list-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 2rem;
    border-radius: 1rem;
    height: fit-content;
  }

  .routes-list-card h2 {
    font-size: 1.3rem;
    margin: 0 0 0.25rem;
    color: var(--text);
  }

  .routes-list-card .subtitle {
    color: var(--muted);
    font-size: 0.85rem;
    margin: 0 0 1.5rem;
  }

  .table-wrapper {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  th {
    text-align: left;
    color: var(--muted);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    padding: 0.75rem 0.5rem;
    border-bottom: 1.5px solid var(--border);
  }

  td {
    padding: 0.9rem 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    color: var(--muted);
  }

  tr:hover td {
    color: var(--text);
    background: rgba(255, 255, 255, 0.008);
  }

  code {
    font-family: monospace;
    font-size: 0.88em;
    background: rgba(255, 255, 255, 0.04);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.03);
  }

  .views-cell {
    font-weight: 600;
    color: var(--text);
  }
</style>
