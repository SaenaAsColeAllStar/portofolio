---
import { getCollection, render } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_TITLE } from "../../consts";

export async function getStaticPaths() {
	const studies = await getCollection("caseStudies");
	return studies.map((study) => ({ params: { slug: study.id }, props: { study } }));
}

const { study } = Astro.props;
const { Content } = await render(study);
---

<!doctype html>
<html lang="en">
	<head><BaseHead title={`${study.data.title} | ${SITE_TITLE}`} description={study.data.excerpt} /></head>
	<body>
		<Header />
		<main>
			<section class="page-hero">
				<p class="eyebrow">Case Study · {study.data.year}</p>
				<h1>{study.data.title}</h1>
				<p class="lede">{study.data.summary}</p>
			</section>
			<section class="grid grid-2 section">
				<div class="card"><h2>Problem</h2><p>{study.data.problem}</p></div>
				<div class="card"><h2>Architecture</h2><p>{study.data.architecture}</p></div>
				<div class="card"><h2>Requirements</h2><ul>{study.data.requirements.map((item) => <li>{item}</li>)}</ul></div>
				<div class="card"><h2>Results</h2><ul>{study.data.results.map((item) => <li>{item}</li>)}</ul></div>
			</section>
			<article class="prose section"><Content /></article>
		</main>
		<Footer />
	</body>
</html>
