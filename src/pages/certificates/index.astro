---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import { SITE_TITLE } from "../../consts";

const certificates = (await getCollection("certificates")).sort(
	(a, b) => b.data.issuedAt.valueOf() - a.data.issuedAt.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Certificates | ${SITE_TITLE}`} description="My certifications and credentials" />
	</head>
	<body>
		<Header />
		<main>
			<section class="section">
				<p class="eyebrow">Certificate Vault</p>
				<h2>Verified Credentials and Qualifications</h2>
				<ul class="certificate-list">
					{
						certificates.map((cert) => (
							<li class="card">
								<a href={`/certificates/${cert.id}`}>
									<h3>{cert.data.title}</h3>
								</a>
								<p class="issuer">Issuer: {cert.data.issuer}</p>
								<p class="date">
									Issued: <FormattedDate date={cert.data.issuedAt} />
								</p>
								<div class="badge-row">
									<span class="badge">{cert.data.category}</span>
									{cert.data.skills.map(skill => <span class="badge secondary">{skill}</span>)}
								</div>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.certificate-list {
		display: grid;
		gap: 1.5rem;
		list-style-type: none;
		margin: 0;
		padding: 0;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		margin-top: 2rem;
	}
	.certificate-list li a {
		text-decoration: none;
	}
	.issuer {
		margin: 0.5rem 0;
		font-weight: 500;
	}
	.date {
		margin-bottom: 1rem;
		font-size: 0.9em;
		opacity: 0.8;
	}
	.badge.secondary {
		background: rgba(255,255,255,0.05);
	}
</style>
