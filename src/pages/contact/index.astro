---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_TITLE } from "../../consts";
import { socials } from "../../data/socials";
---

<!doctype html>
<html lang="en">
	<head><BaseHead title={`Contact | ${SITE_TITLE}`} description="Contact CTOS for professional opportunities, collaboration, or technical discussion." /></head>
	<body>
		<Header />
		<main>
			<section class="page-hero">
				<p class="eyebrow">Contact</p>
				<h1>Let’s discuss reliable digital systems.</h1>
				<p class="lede">Use email, LinkedIn, or GitHub to reach out about professional opportunities, product engineering, automation, or infrastructure work.</p>
			</section>
			<section class="grid grid-3 section">
				{socials.map((social) => <article class="card"><p class="eyebrow">{social.label}</p><h2>{social.username}</h2><a class="button secondary" href={social.href}>Open {social.label}</a></article>)}
			</section>
		</main>
		<Footer />
	</body>
</html>
