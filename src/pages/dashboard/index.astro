<script>
  function initDashboard() {
    const tabTriggers = document.querySelectorAll(".tab-trigger");
    const tabContents = document.querySelectorAll(".tab-content");

    // 1. Tab Navigation & Persistence Logic
    // Check url hash or parameter for active tab
    const urlParams = new URLSearchParams(window.location.search);
    const hash = window.location.hash.replace("#", "");
    const initialTab = hash || urlParams.get("tab");
    if (initialTab) {
      const trigger = document.querySelector(`.tab-trigger[data-tab="${initialTab}"]`);
      if (trigger) {
        tabTriggers.forEach((t) => t.classList.remove("active"));
        tabContents.forEach((c) => c.classList.remove("active"));
        trigger.classList.add("active");
        document.getElementById(`tab-${initialTab}`)?.classList.add("active");
      }
    }

    tabTriggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const targetTab = trigger.getAttribute("data-tab");

        tabTriggers.forEach((t) => t.classList.remove("active"));
        tabContents.forEach((c) => c.classList.remove("active"));

        trigger.classList.add("active");
        document.getElementById(`tab-${targetTab}`)?.classList.add("active");

        // Persist tab state in URL hash
        window.location.hash = targetTab;
      });
    });

    // 2. Profile Photo Canvas WebP Converter Logic
    const photoInput = document.getElementById("profile_photo_input") as HTMLInputElement;
    const fileNameInfo = document.getElementById("file-name-info");
    const base64Input = document.getElementById("profile_photo_base64") as HTMLInputElement;
    const previewImg = document.getElementById("avatar-preview") as HTMLImageElement;
    const fallbackDiv = document.getElementById("avatar-fallback");
    const saveBtn = document.getElementById("save-photo-btn") as HTMLButtonElement;

    if (photoInput) {
      photoInput.addEventListener("change", (event) => {
        const target = event.target as HTMLInputElement;
        const file = target.files?.[0];
        if (!file) return;

        if (fileNameInfo) {
          fileNameInfo.textContent = file.name;
        }

        const reader = new FileReader();
        reader.onload = (e) => {
          const img = new Image();
          img.onload = () => {
            const canvas = document.createElement("canvas");
            let width = img.width;
            let height = img.height;
            const maxDim = 320;

            if (width > maxDim || height > maxDim) {
              if (width > height) {
                height = Math.round((height * maxDim) / width);
                width = maxDim;
              } else {
                width = Math.round((width * maxDim) / height);
                height = maxDim;
              }
            }

            canvas.width = width;
            canvas.height = height;
            const ctx = canvas.getContext("2d");
            if (ctx) {
              ctx.drawImage(img, 0, 0, width, height);
              const base64Data = canvas.toDataURL("image/webp", 0.75);
              if (base64Input) {
                base64Input.value = base64Data;
              }
              if (previewImg) {
                previewImg.src = base64Data;
                previewImg.classList.remove("hidden");
              }
              if (fallbackDiv) {
                fallbackDiv.classList.add("hidden");
              }
              if (saveBtn) {
                saveBtn.removeAttribute("disabled");
              }
            }
          };
          if (e.target?.result) {
            img.src = e.target.result as string;
          }
        };
        reader.readAsDataURL(file);
      });
    }

    // 2. AJAX Deletion Moderation for Guestbook
    const deleteButtons = document.querySelectorAll(".delete-entry-btn");

    deleteButtons.forEach((btn) => {
      btn.addEventListener("click", async () => {
        const entryId = btn.getAttribute("data-id");
        if (!entryId) return;

        if (confirm("Are you sure you want to delete this guestbook signature? This action cannot be undone.")) {
          try {
            btn.setAttribute("disabled", "true");
            btn.textContent = "Deleting...";

            const res = await fetch("/api/admin/guestbook-delete", {
              method: "POST",
              headers: {
                "content-type": "application/json"
              },
              body: JSON.stringify({ id: parseInt(entryId, 10) })
            });

            const data = await res.json() as any;

            if (res.ok && data.success) {
              const card = document.getElementById(`entry-${entryId}`);
              if (card) {
                // Apply a premium fade-out effect and remove it
                card.style.transition = "opacity 0.4s, transform 0.4s";
                card.style.opacity = "0";
                card.style.transform = "scale(0.95)";
                setTimeout(() => {
                  card.remove();
                  // Update tab count indicator
                  const tabBtn = document.querySelector('[data-tab="guestbook"]');
                  if (tabBtn) {
                    const remainingCards = document.querySelectorAll(".mod-entry-card").length;
                    tabBtn.textContent = `Guestbook Moderation (${remainingCards})`;
                  }
                }, 400);
              }
            } else {
              throw new Error(data.error || "Failed to delete entry.");
            }
          } catch (err: any) {
            alert(err.message || "An error occurred while deleting entry.");
            btn.removeAttribute("disabled");
            btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg> Delete`;
          }
        }
      });
    });
  }

  // Hook to Astro swap
  document.addEventListener("astro:page-load", initDashboard);
</script>
