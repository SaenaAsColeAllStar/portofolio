---
export const prerender = false;

import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_TITLE } from "../../consts";
import { getAuthConfig, verifySessionToken, hashPassword, createSessionToken } from "../../utils/auth";
import { getDb } from "../../db";
import { pageViews, guestbook, contactSubmissions, adminCredentials, settings } from "../../db/schema";
import { desc, sql } from "drizzle-orm";

const env = Astro.locals.runtime?.env;
const { secret } = getAuthConfig(env);

// 1. Verify Authenticated Session
const cookieToken = Astro.cookies.get("ctos_session")?.value;
const session = await verifySessionToken(cookieToken, secret);

if (!session) {
  return Astro.redirect("/dashboard/login");
}

let activeTab = "telemetry";
let successMsg: string | null = null;
let settingsErrorMsg: string | null = null;

// 2. Handle Actions (Logout, Credentials Update, Profile Photo Update)
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action")?.toString();

    if (action === "update_credentials" || action === "update_profile_photo") {
      activeTab = "settings";
    }

    if (action === "logout") {
      Astro.cookies.delete("ctos_session", { path: "/" });
      return Astro.redirect("/");
    }

    const db = getDb(env);

    if (action === "update_credentials") {
      const newUsername = formData.get("username")?.toString().trim();
      const newPassword = formData.get("new_password")?.toString();
      const confirmPassword = formData.get("confirm_password")?.toString();
      const currentPassword = formData.get("current_password")?.toString();

      if (!newUsername || !newPassword || !confirmPassword || !currentPassword) {
        settingsErrorMsg = "All credential fields are required.";
      } else if (newPassword !== confirmPassword) {
        settingsErrorMsg = "New passwords do not match.";
      } else {
        // Verify current password
        let isAuthorized = false;
        const storedCreds = await db.select().from(adminCredentials).limit(1);

        if (storedCreds.length > 0) {
          const dbCreds = storedCreds[0];
          const currentHashed = await hashPassword(currentPassword);
          if (dbCreds.username === session.username && currentHashed === dbCreds.passwordHash) {
            isAuthorized = true;
          }
        } else {
          // Fallback to default env vars
          const { username: defUser, password: defPass } = getAuthConfig(env);
          if (defUser === session.username && defPass === currentPassword) {
            isAuthorized = true;
          }
        }

        if (isAuthorized) {
          const newHashed = await hashPassword(newPassword);
          
          if (storedCreds.length > 0) {
            await db.update(adminCredentials)
              .set({
                username: newUsername,
                passwordHash: newHashed,
                updatedAt: new Date()
              })
              .where(sql`id = ${storedCreds[0].id}`);
          } else {
            await db.insert(adminCredentials)
              .values({
                username: newUsername,
                passwordHash: newHashed
              });
          }

          // Reset session cookie with new username
          const token = await createSessionToken(newUsername, secret);
          Astro.cookies.set("ctos_session", token, {
            path: "/",
            httpOnly: true,
            secure: true,
            sameSite: "strict",
            maxAge: 24 * 60 * 60
          });

          successMsg = "Administrator credentials updated successfully.";
          session.username = newUsername;
        } else {
          settingsErrorMsg = "Current password verification failed.";
        }
      }
    }

    if (action === "update_profile_photo") {
      const base64Data = formData.get("profile_photo_base64")?.toString();

      if (!base64Data || !base64Data.startsWith("data:image/webp;base64,")) {
        settingsErrorMsg = "Invalid profile photo format. Must be compressed WebP.";
      } else {
        // Save in settings table
        const existingPhoto = await db.select().from(settings).where(sql`key = 'profile_photo'`).limit(1);

        if (existingPhoto.length > 0) {
          await db.update(settings)
            .set({ value: base64Data, updatedAt: new Date() })
            .where(sql`key = 'profile_photo'`);
        } else {
          await db.insert(settings)
            .values({ key: "profile_photo", value: base64Data });
        }

        successMsg = "Profile photo uploaded and compressed successfully.";
      }
    }
  } catch (err: any) {
    console.error("Dashboard action error:", err);
    settingsErrorMsg = err.message || "An error occurred while executing setting update.";
  }
}

// 3. Fetch Telemetry & Database Metrics
let totalViews = 0;
let totalGuestbook = 0;
let totalContact = 0;
let dbLatency = 0;
let topViews: any[] = [];
let allViews: any[] = [];
let contacts: any[] = [];
let guestbookEntries: any[] = [];
let currentPhoto: string | null = null;
let error = null;

try {
  const db = getDb(env);

  // Measure database latency
  const start = Date.now();
  await db.execute(sql`SELECT 1`);
  dbLatency = Date.now() - start;

  // Sum total views
  const viewsSum = await db.select({ total: sql<number>`sum(count)` }).from(pageViews);
  totalViews = Number(viewsSum[0]?.total || 0);

  // Count guestbook entries
  const gbCount = await db.select({ count: sql<number>`count(*)` }).from(guestbook);
  totalGuestbook = Number(gbCount[0]?.count || 0);

  // Count contact submissions
  const contactCount = await db.select({ count: sql<number>`count(*)` }).from(contactSubmissions);
  totalContact = Number(contactCount[0]?.count || 0);

  // Fetch top 5 page views for SVG Chart
  topViews = await db.select()
    .from(pageViews)
    .orderBy(desc(pageViews.count))
    .limit(5);

  // Fetch all page views
  allViews = await db.select()
    .from(pageViews)
    .orderBy(desc(pageViews.count));

  // Fetch private contact submissions (latest 50)
  contacts = await db.select()
    .from(contactSubmissions)
    .orderBy(desc(contactSubmissions.createdAt))
    .limit(50);

  // Fetch guestbook entries for moderation (latest 100)
  guestbookEntries = await db.select()
    .from(guestbook)
    .orderBy(desc(guestbook.createdAt))
    .limit(100);

  // Fetch profile photo from settings
  const photoRow = await db.select().from(settings).where(sql`key = 'profile_photo'`).limit(1);
  if (photoRow.length > 0) {
    currentPhoto = photoRow[0].value;
  }

} catch (e) {
  console.error("Dashboard telemetry error:", e);
  error = "Failed to synchronize system telemetry data.";
}

// Time Formatting Helper for Jakarta (WIB)
function formatJakartaTime(date: Date): string {
  return new Intl.DateTimeFormat("en-US", {
    timeZone: "Asia/Jakarta",
    year: "numeric",
    month: "short",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
    hour12: false
  }).format(date) + " WIB";
}

// Chart layout constants
const maxViewCount = topViews.length > 0 ? Math.max(...topViews.map(v => v.count)) : 100;
const chartHeight = 240;
const chartWidth = 500;
const paddingLeft = 140;
const paddingRight = 50;
const barWidth = 24;
const gap = 16;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`System Dashboard | ${SITE_TITLE}`} description="Administrator control panel." />
  </head>
  <body>
    <Header />
    <main class="dashboard-container">
      <!-- Dashboard Hero -->
      <section class="page-hero dashboard-hero-sec">
        <div class="hero-split">
          <div>
            <p class="eyebrow">Admin Console</p>
            <h1>System Node Dashboard</h1>
            <p class="lede">Telemetry and database management interface for CTOS Portfolio Node.</p>
          </div>
          <form method="POST">
            <input type="hidden" name="action" value="logout" />
            <button type="submit" class="logout-btn button secondary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                <polyline points="16 17 21 12 16 7"></polyline>
                <line x1="21" y1="12" x2="9" y2="12"></line>
              </svg>
              Logout Node
            </button>
          </form>
        </div>
      </section>

      {error ? (
        <section class="error-container section">
          <div class="status-card error">
            <h2>Critical Telemetry Sync Failure</h2>
            <p>{error}</p>
          </div>
        </section>
      ) : (
        <>
        <!-- Navigation Tabs -->
        <div class="dashboard-tabs">
          <button class={activeTab === 'telemetry' ? 'tab-trigger active' : 'tab-trigger'} data-tab="telemetry">System Telemetry</button>
          <button class={activeTab === 'contact' ? 'tab-trigger active' : 'tab-trigger'} data-tab="contact">Contact Messages ({contacts.length})</button>
          <button class={activeTab === 'guestbook' ? 'tab-trigger active' : 'tab-trigger'} data-tab="guestbook">Guestbook Moderation ({guestbookEntries.length})</button>
          <button class={activeTab === 'settings' ? 'tab-trigger active' : 'tab-trigger'} data-tab="settings">System Settings</button>
        </div>

        {successMsg && (
          <div class="settings-banner success">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            <span>{successMsg}</span>
          </div>
        )}
        {settingsErrorMsg && (
          <div class="settings-banner error">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            <span>{settingsErrorMsg}</span>
          </div>
        )}

        <!-- Tab contents -->
        <div class={activeTab === 'telemetry' ? 'tab-content active' : 'tab-content'} id="tab-telemetry">
          <div class="dashboard-layout-grid section">
            <!-- Left Column - Cards & Chart -->
            <div class="dashboard-main-col">
              <!-- Stats Grid -->
              <div class="stats-card-grid">
                <article class="stat-card">
                  <div class="stat-header">
                    <span class="stat-label">Total Hits</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                  </div>
                  <div class="stat-value">{totalViews.toLocaleString()}</div>
                </article>

                <article class="stat-card">
                  <div class="stat-header">
                    <span class="stat-label">Signatures</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                  </div>
                  <div class="stat-value">{totalGuestbook}</div>
                </article>

                <article class="stat-card">
                  <div class="stat-header">
                    <span class="stat-label">Messages</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                  </div>
                  <div class="stat-value">{totalContact}</div>
                </article>

                <article class="stat-card">
                  <div class="stat-header">
                    <span class="stat-label">DB Latency</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                  </div>
                  <div class="stat-value select-latency">{dbLatency} <span class="ms-label">ms</span></div>
                </article>
              </div>

              <!-- SVG Traffic Chart -->
              <div class="chart-container-card">
                <h2>Top Routes Traffic</h2>
                <div class="svg-chart-wrapper">
                  {topViews.length === 0 ? (
                    <p class="empty-chart">No traffic data available.</p>
                  ) : (
                    <svg viewBox={`0 0 ${chartWidth} ${chartHeight}`} class="svg-chart">
                      <defs>
                        <linearGradient id="barGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                          <stop offset="0%" stop-color="var(--accent, #4f8cff)" stop-opacity="0.1" />
                          <stop offset="100%" stop-color="var(--accent, #4f8cff)" stop-opacity="0.9" />
                        </linearGradient>
                      </defs>

                      {topViews.map((item, index) => {
                        const y = index * (barWidth + gap) + 20;
                        const maxBarWidth = chartWidth - paddingLeft - paddingRight;
                        const width = Math.max(8, Math.round((item.count / maxViewCount) * maxBarWidth));
                        
                        return (
                          <g class="chart-group">
                            <text 
                              x={paddingLeft - 12} 
                              y={y + barWidth / 2 + 5} 
                              class="chart-label"
                              text-anchor="end"
                            >
                              {item.path === '/' ? '/home' : item.path}
                            </text>

                            <rect 
                              x={paddingLeft} 
                              y={y} 
                              width={maxBarWidth} 
                              height={barWidth} 
                              rx="4" 
                              class="bar-track" 
                            />

                            <rect 
                              x={paddingLeft} 
                              y={y} 
                              width={width} 
                              height={barWidth} 
                              rx="4" 
                              fill="url(#barGrad)"
                              class="bar-fill"
                            />

                            <text 
                              x={paddingLeft + width + 10} 
                              y={y + barWidth / 2 + 5} 
                              class="chart-value"
                            >
                              {item.count}
                            </text>
                          </g>
                        );
                      })}

                      <line 
                        x1={paddingLeft} 
                        y1="10" 
                        x2={paddingLeft} 
                        y2={topViews.length * (barWidth + gap) + 10} 
                        class="chart-axis" 
                      />
                    </svg>
                  )}
                </div>
              </div>
            </div>

            <!-- Right Column - Routes Table -->
            <div class="dashboard-side-col">
              <div class="routes-list-card">
                <h2>Node Path Directory</h2>
                <p class="subtitle">Detailed view count across all registered paths.</p>

                <div class="table-wrapper">
                  <table>
                    <thead>
                      <tr>
                        <th>Path</th>
                        <th align="right">Views</th>
                      </tr>
                    </thead>
                    <tbody>
                      {allViews.map((item) => (
                        <tr>
                          <td><code>{item.path}</code></td>
                          <td align="right" class="views-cell">{item.count.toLocaleString()}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Private Contact Submissions Tab -->
        <div class={activeTab === 'contact' ? 'tab-content active' : 'tab-content'} id="tab-contact">
          <div class="dashboard-details-section section">
            <div class="routes-list-card width-full">
              <h2>Contact Message Inquiries</h2>
              <p class="subtitle">Incoming system contact inquiries. Sourced privately.</p>

              {contacts.length === 0 ? (
                <div class="empty-state">No contact submissions found.</div>
              ) : (
                <div class="table-wrapper">
                  <table class="contacts-table">
                    <thead>
                      <tr>
                        <th>Sender Detail</th>
                        <th>Subject / Request</th>
                        <th>Message Content</th>
                        <th>Received Timestamp</th>
                      </tr>
                    </thead>
                    <tbody>
                      {contacts.map((c) => (
                        <tr>
                          <td class="sender-cell">
                            <strong>{c.name}</strong>
                            <span class="email-sub">{c.email}</span>
                          </td>
                          <td class="subject-cell">
                            <span class="subject-badge">{c.subject}</span>
                          </td>
                          <td class="message-content-cell">
                            <div class="msg-box">{c.message}</div>
                          </td>
                          <td class="timestamp-cell">{formatJakartaTime(c.createdAt)}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
            </div>
          </div>
        </div>

        <!-- Guestbook Moderation Tab -->
        <div class={activeTab === 'guestbook' ? 'tab-content active' : 'tab-content'} id="tab-guestbook">
          <div class="dashboard-details-section section">
            <div class="routes-list-card width-full">
              <h2>Guestbook Signatures Moderation</h2>
              <p class="subtitle">Manage public sign-offs and delete inappropriate or spam entries.</p>

              {guestbookEntries.length === 0 ? (
                <div class="empty-state">No guestbook signatures recorded.</div>
              ) : (
                <div class="guestbook-mod-grid">
                  {guestbookEntries.map((entry) => (
                    <article class="mod-entry-card" id={`entry-${entry.id}`}>
                      <div class="entry-card-header">
                        <div>
                          <strong>{entry.name}</strong>
                          <span class="entry-time">{formatJakartaTime(entry.createdAt)}</span>
                        </div>
                        <button 
                          class="delete-entry-btn" 
                          data-id={entry.id}
                          aria-label="Delete Entry"
                        >
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                            <line x1="10" y1="11" x2="10" y2="17"></line>
                            <line x1="14" y1="11" x2="14" y2="17"></line>
                          </svg>
                          Delete
                        </button>
                      </div>
                      <div class="entry-card-body">
                        "{entry.message}"
                      </div>
                    </article>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>

        <!-- System Settings Tab -->
        <div class={activeTab === 'settings' ? 'tab-content active' : 'tab-content'} id="tab-settings">
          <div class="dashboard-layout-grid section">
            <!-- Left Column: Credentials Form -->
            <div class="dashboard-main-col">
              <div class="routes-list-card">
                <h2>Administrative Credentials</h2>
                <p class="subtitle">Modify the administrator username and security password.</p>
                
                <form method="POST" class="settings-form">
                  <input type="hidden" name="action" value="update_credentials" />
                  
                  <div class="input-group">
                    <label for="username">Administrator Username</label>
                    <input 
                      type="text" 
                      id="username" 
                      name="username" 
                      value={session.username} 
                      required 
                      autocomplete="username"
                    />
                  </div>

                  <div class="input-row">
                    <div class="input-group">
                      <label for="new_password">New Password</label>
                      <input 
                        type="password" 
                        id="new_password" 
                        name="new_password" 
                        placeholder="••••••••"
                        required
                        autocomplete="new-password"
                      />
                    </div>

                    <div class="input-group">
                      <label for="confirm_password">Confirm New Password</label>
                      <input 
                        type="password" 
                        id="confirm_password" 
                        name="confirm_password" 
                        placeholder="••••••••"
                        required
                        autocomplete="new-password"
                      />
                    </div>
                  </div>

                  <hr class="form-divider" />

                  <div class="input-group">
                    <label for="current_password">Current Password (to authorize change)</label>
                    <input 
                      type="password" 
                      id="current_password" 
                      name="current_password" 
                      placeholder="••••••••"
                      required
                      autocomplete="current-password"
                    />
                  </div>

                  <button type="submit" class="submit-btn">Update Admin Credentials</button>
                </form>
              </div>
            </div>

            <!-- Right Column: Profile Photo Form -->
            <div class="dashboard-side-col">
              <div class="routes-list-card">
                <h2>Profile Image Settings</h2>
                <p class="subtitle">Upload and crop profile photo. Converts client-side to WebP.</p>
                
                <form method="POST" class="settings-form" id="profile-photo-form">
                  <input type="hidden" name="action" value="update_profile_photo" />
                  <input type="hidden" id="profile_photo_base64" name="profile_photo_base64" />

                  <div class="profile-preview-container">
                    <div class="avatar-preview-wrapper">
                      {currentPhoto ? (
                        <img id="avatar-preview" src={currentPhoto} alt="Admin profile preview" />
                      ) : (
                        <div id="avatar-fallback" class="avatar-fallback">
                          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                          </svg>
                        </div>
                        <img id="avatar-preview" class="hidden" alt="Admin profile preview" />
                      )}
                    </div>
                    
                    <div class="file-upload-wrapper">
                      <label for="profile_photo_input" class="file-upload-label button secondary">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                          <polyline points="17 8 12 3 7 8"></polyline>
                          <line x1="12" y1="3" x2="12" y2="15"></line>
                        </svg>
                        Choose Photo
                      </label>
                      <input 
                        type="file" 
                        id="profile_photo_input" 
                        accept="image/*" 
                        style="display: none;" 
                      />
                      <span class="file-name-info" id="file-name-info">No file chosen</span>
                    </div>
                  </div>

                  <p class="photo-info-text">
                    Supported formats: PNG, JPG, WebP. The image is scaled client-side to a max of 320x320 pixels and converted to highly optimized WebP format to minimize database footprint.
                  </p>

                  <button type="submit" class="submit-btn" id="save-photo-btn" disabled>
                    Save Profile Photo
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
        </>
      )}
    </main>
    <Footer />
  </body>
</html>

<style>
  .dashboard-container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 1rem;
    min-height: 80vh;
  }

  .dashboard-hero-sec {
    margin-bottom: 2rem;
  }

  .hero-split {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .logout-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
    cursor: pointer;
  }

  /* Tabs Navigation */
  .dashboard-tabs {
    display: flex;
    border-bottom: 1px solid var(--border);
    gap: 1rem;
    margin-bottom: 2rem;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .dashboard-tabs::-webkit-scrollbar {
    display: none;
  }

  .tab-trigger {
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 0.85rem 0.5rem;
    color: var(--muted);
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .tab-trigger:hover {
    color: var(--text);
  }

  .tab-trigger.active {
    color: var(--text);
    border-color: var(--accent, #4f8cff);
  }

  /* Tab Visibility */
  .tab-content {
    display: none;
  }
  .tab-content.active {
    display: block;
  }

  /* General Grid Layouts */
  .dashboard-layout-grid {
    display: grid;
    grid-template-columns: 1.40fr 1fr;
    gap: 2.5rem;
    padding-bottom: 6rem;
  }

  .dashboard-details-section {
    padding-bottom: 6rem;
  }

  @media (max-width: 900px) {
    .dashboard-layout-grid {
