---
export const prerender = false;

import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_TITLE } from "../../consts";
import { getAuthConfig, createSessionToken, verifySessionToken } from "../../utils/auth";

let errorMsg: string | null = null;
const env = Astro.locals.runtime?.env;
const { secret, username: correctUsername, password: correctPassword } = getAuthConfig(env);

// 1. Check if already logged in
const cookieToken = Astro.cookies.get("ctos_session")?.value;
const existingSession = await verifySessionToken(cookieToken, secret);

if (existingSession) {
  return Astro.redirect("/dashboard");
}

// 2. Handle POST Request
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const inputUsername = formData.get("username")?.toString().trim();
    const inputPassword = formData.get("password")?.toString();

    if (inputUsername === correctUsername && inputPassword === correctPassword) {
      // Create session
      const token = await createSessionToken(correctUsername, secret);
      
      // Set secure cookie
      Astro.cookies.set("ctos_session", token, {
        path: "/",
        httpOnly: true,
        secure: true,
        sameSite: "strict",
        maxAge: 24 * 60 * 60 // 1 day in seconds
      });

      return Astro.redirect("/dashboard");
    } else {
      errorMsg = "Invalid system administrator credentials.";
    }
  } catch (err) {
    console.error("Login processing error:", err);
    errorMsg = "An error occurred while processing login request.";
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`System Login | ${SITE_TITLE}`} description="Administrator authentication portal." />
  </head>
  <body>
    <Header />
    <main class="login-wrapper">
      <div class="login-card">
        <div class="login-header">
          <div class="shield-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          </div>
          <h1>System Authentication</h1>
          <p class="subtitle">Access limited to authorized nodes only.</p>
        </div>

        {errorMsg && (
          <div class="error-banner">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            <span>{errorMsg}</span>
          </div>
        )}

        <form method="POST" class="login-form">
          <div class="input-group">
            <label for="username">Access Key (Username)</label>
            <input 
              type="text" 
              id="username" 
              name="username" 
              placeholder="Enter administrator ID..." 
              required 
              autocomplete="username" 
            />
          </div>

          <div class="input-group">
            <label for="password">Security Cipher (Password)</label>
            <input 
              type="password" 
              id="password" 
              name="password" 
              placeholder="Enter system cipher..." 
              required 
              autocomplete="current-password" 
            />
          </div>

          <button type="submit" class="submit-btn">
            Decrypt & Authorize
          </button>
        </form>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .login-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    padding: 2rem 1rem;
  }

  .login-card {
    background: var(--surface, rgba(18, 26, 44, 0.8));
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border, rgba(255, 255, 255, 0.08));
    border-radius: 1.25rem;
    padding: 2.5rem;
    width: 100%;
    max-width: 26rem;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.6);
  }

  .login-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .shield-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: 50%;
    width: 4rem;
    height: 4rem;
    color: var(--accent, #4f8cff);
    margin-bottom: 1.25rem;
    box-shadow: 0 0 20px rgba(79, 140, 255, 0.15);
  }

  .login-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.5rem;
  }

  .login-header .subtitle {
    font-size: 0.88rem;
    color: var(--muted);
  }

  /* Error Banner */
  .error-banner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(231, 76, 60, 0.08);
    border: 1px solid rgba(231, 76, 60, 0.25);
    color: #e74c3c;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    margin-bottom: 1.5rem;
    font-size: 0.88rem;
  }

  .error-banner svg {
    flex-shrink: 0;
  }

  /* Form */
  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .input-group label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .input-group input {
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .input-group input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(79, 140, 255, 0.15);
  }

  .submit-btn {
    background: var(--text, #fff);
    color: var(--bg, #0b111e);
    border: none;
    border-radius: 0.75rem;
    padding: 0.85rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    margin-top: 0.5rem;
  }

  .submit-btn:hover {
    opacity: 0.9;
  }

  .submit-btn:active {
    transform: scale(0.98);
  }
</style>
