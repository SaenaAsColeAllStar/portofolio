---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { proofSignals } from "../data/metrics";
import { positioning } from "../data/positioning";
import { capabilityMatrix } from "../data/skills";

const projects = await getCollection("projects");
const caseStudies = await getCollection("caseStudies");
const featuredProjects = projects.filter((project) => project.data.featured).slice(0, 3);
const featuredCaseStudy = caseStudies.find((study) => study.id === "smk-teknovo-ecosystem") ?? caseStudies[0];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-copy">
					<p class="eyebrow">{positioning.title}</p>
					<h1>{positioning.headline}</h1>
					<p class="lede">{positioning.subheadline}</p>
					<div class="button-row">
						<a class="button" href={positioning.primaryCta.href}>{positioning.primaryCta.label}</a>
						<a class="button secondary" href={positioning.secondaryCta.href}>{positioning.secondaryCta.label}</a>
					</div>
				</div>
				<div class="system-card card" aria-label="System capability map">
					<span>Infrastructure</span>
					<span>Automation</span>
					<span>AI Workflows</span>
					<span>Product Engineering</span>
					<span>System Architecture</span>
				</div>
			</section>

			<section class="section">
				<p class="eyebrow">Proof Snapshot</p>
				<h2>Systems thinking before stack lists.</h2>
				<div class="grid grid-3 proof-grid">
					{proofSignals.map((signal) => (
						<article class="card">
							<p class="eyebrow">{signal.label}</p>
							<h3>{signal.value}</h3>
							<p>{signal.description}</p>
						</article>
					))}
				</div>
			</section>

			{featuredCaseStudy && (
				<section class="section featured card">
					<div>
						<p class="eyebrow">Featured Case Study</p>
						<h2>{featuredCaseStudy.data.title}</h2>
						<p>{featuredCaseStudy.data.summary}</p>
					</div>
					<a class="button" href={`/case-studies/${featuredCaseStudy.id}`}>Read Case Study</a>
				</section>
			)}

			<section class="section">
				<p class="eyebrow">Capability Matrix</p>
				<h2>Core domains connected into one architecture-first portfolio.</h2>
				<div class="grid grid-3">
					{capabilityMatrix.map((capability) => (
						<article class="card">
							<h3>{capability.name}</h3>
							<p>{capability.description}</p>
						</article>
					))}
				</div>
			</section>

			<section class="section">
				<div class="section-heading">
					<div>
						<p class="eyebrow">Selected Projects</p>
						<h2>Project evidence with role, architecture, and impact.</h2>
					</div>
					<a href="/projects">View all projects</a>
				</div>
				<div class="grid grid-2">
					{featuredProjects.map((project) => (
						<article class="card project-card">
							<p class="eyebrow">{project.data.category}</p>
							<h3><a href={`/projects/${project.id}`}>{project.data.title}</a></h3>
							<p>{project.data.excerpt}</p>
							<div class="badge-row">
								{project.data.domains.map((domain) => <span class="badge">{domain}</span>)}
							</div>
						</article>
					))}
				</div>
			</section>

			<section class="section cta card">
				<div>
					<p class="eyebrow">Resume & Contact</p>
					<h2>Need a systems-focused engineer?</h2>
					<p>Review the resume summary or reach out directly through email, LinkedIn, or GitHub.</p>
				</div>
				<div class="button-row">
					<a class="button" href="/resume">View Resume</a>
					<a class="button secondary" href="/contact">Contact</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		align-items: center;
		display: grid;
		gap: 2rem;
		grid-template-columns: 1.15fr 0.85fr;
		min-height: calc(100vh - 72px);
		padding: 4rem 0;
	}

	.hero-copy {
		display: grid;
		gap: 1.25rem;
	}

	.system-card {
		display: grid;
		gap: 0.75rem;
		padding: 2rem;
	}

	.system-card span {
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 0.8rem 1rem;
	}

	.proof-grid,
	.section-heading {
		margin-top: 1.5rem;
	}

	.featured,
	.cta,
	.section-heading {
		align-items: center;
		display: flex;
		gap: 1.5rem;
		justify-content: space-between;
	}

	.section-heading a,
	.project-card a {
		text-decoration: none;
	}

	.project-card {
		display: grid;
		gap: 1rem;
	}

	@media (max-width: 860px) {
		.hero,
		.featured,
		.cta,
		.section-heading {
			align-items: stretch;
			grid-template-columns: 1fr;
			flex-direction: column;
		}
	}
</style>
