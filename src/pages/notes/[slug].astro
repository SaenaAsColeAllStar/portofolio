---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";

export async function getStaticPaths() {
	const notes = await getCollection("notes");
	return notes.map((note) => ({
		params: { slug: note.id },
		props: note,
	}));
}

type Props = CollectionEntry<"notes">;
const note = Astro.props;
const { Content } = await render(note);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${note.data.title} | Notes`} description={note.data.excerpt} />
	</head>
	<body>
		<Header />
		<main>
			<article class="section note-detail">
				<a href="/notes" class="back-link">&larr; Back to Notes</a>
				<div class="card note-header">
					<p class="eyebrow">{note.data.category}</p>
					<h1>{note.data.title}</h1>
					<p class="date">Published: <FormattedDate date={note.data.publishedAt} /></p>
					
					<div class="badge-row" style="margin-top: 1.5rem;">
						{note.data.tags.map((tag) => <span class="badge">{tag}</span>)}
					</div>
				</div>
				<div class="prose">
					<Content />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.note-detail {
		max-width: 800px;
	}
	.back-link {
		display: inline-block;
		margin-bottom: 2rem;
		text-decoration: none;
		opacity: 0.8;
	}
	.back-link:hover {
		opacity: 1;
	}
	.note-header {
		margin-bottom: 2rem;
	}
	.note-header h1 {
		margin: 0.5rem 0;
	}
	.date {
		margin: 0.25rem 0;
		opacity: 0.8;
	}
	.prose {
		margin-top: 2rem;
	}
</style>
