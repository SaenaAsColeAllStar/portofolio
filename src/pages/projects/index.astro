---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_TITLE } from "../../consts";

const projects = await getCollection("projects");

const allCategories = [...new Set(projects.map((p) => p.data.category))].sort();
---

<!doctype html>
<html lang="en">
	<head><BaseHead title={`Projects | ${SITE_TITLE}`} description="Selected CTOS projects organized by category, role, stack, and impact." /></head>
	<body>
		<Header />
		<main>
			<section class="page-hero">
				<p class="eyebrow">Projects</p>
				<h1>Systems, workflows, and product evidence.</h1>
				<p class="lede">Projects are framed around context, role, architecture, stack, and impact rather than screenshots alone.</p>
			</section>

			<section class="section filters">
				<div class="filter-controls">
					<input type="text" id="projectSearch" placeholder="Search projects by keyword..." />
					<select id="categoryFilter" aria-label="Filter by category">
						<option value="all">All Categories</option>
						{allCategories.map(cat => <option value={cat}>{cat}</option>)}
					</select>
				</div>
			</section>

			<section class="grid grid-2 section" id="projectGrid">
				{projects.map((project) => (
					<article class="card project-card" data-category={project.data.category} data-title={project.data.title.toLowerCase()} data-excerpt={project.data.excerpt.toLowerCase()}>
						<p class="eyebrow">{project.data.category} · {project.data.year}</p>
						<h2><a href={`/projects/${project.id}`}>{project.data.title}</a></h2>
						<p>{project.data.excerpt}</p>
						<p><strong>Role:</strong> {project.data.role}</p>
						{project.data.impact && <p><strong>Impact:</strong> {project.data.impact}</p>}
						<div class="badge-row">
							{project.data.stack.map((item) => <span class="badge">{item}</span>)}
						</div>
					</article>
				))}
				<div id="noResults" class="hidden">No projects found matching your criteria.</div>
			</section>
		</main>
		<Footer />

		<script>
			document.addEventListener('DOMContentLoaded', () => {
				const searchInput = document.getElementById('projectSearch') as HTMLInputElement;
				const categorySelect = document.getElementById('categoryFilter') as HTMLSelectElement;
				const projectCards = document.querySelectorAll('.project-card');
				const noResults = document.getElementById('noResults');

				function filterProjects() {
					const searchTerm = searchInput.value.toLowerCase();
					const selectedCategory = categorySelect.value;
					let visibleCount = 0;

					projectCards.forEach((card) => {
						const htmlCard = card as HTMLElement;
						const title = htmlCard.dataset.title || '';
						const excerpt = htmlCard.dataset.excerpt || '';
						const category = htmlCard.dataset.category || '';

						const matchesSearch = title.includes(searchTerm) || excerpt.includes(searchTerm);
						const matchesCategory = selectedCategory === 'all' || category === selectedCategory;

						if (matchesSearch && matchesCategory) {
							htmlCard.style.display = 'grid';
							visibleCount++;
						} else {
							htmlCard.style.display = 'none';
						}
					});

					if (noResults) {
						noResults.style.display = visibleCount === 0 ? 'block' : 'none';
					}
				}

				searchInput?.addEventListener('input', filterProjects);
				categorySelect?.addEventListener('change', filterProjects);
			});
		</script>
	</body>
</html>

<style>
	.filters {
		margin-bottom: 2rem;
	}
	.filter-controls {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.filter-controls input, .filter-controls select {
		padding: 0.75rem 1rem;
		border-radius: 6px;
		border: 1px solid var(--border);
		background: transparent;
		color: var(--text);
		font-family: inherit;
		min-width: 200px;
	}
	.filter-controls input:focus, .filter-controls select:focus {
		outline: 2px solid var(--text);
		outline-offset: 2px;
	}
	.filter-controls input {
		flex: 1;
	}
	.project-card {
		display: grid;
		gap: 1rem;
	}
	.project-card a {
		text-decoration: none;
	}
	.hidden {
		display: none;
		grid-column: 1 / -1;
		text-align: center;
		padding: 3rem;
		opacity: 0.7;
	}
</style>
