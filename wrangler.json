{
    "name": "portfolio",
    "compatibility_date": "2025-10-08",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "main": "./dist/_worker.js/index.js",
    "assets": {
        "directory": "./dist",
        "binding": "ASSETS"
    },
    "observability": {
        "enabled": true,
        "logs": {
            "enabled": true,
            "invocation_logs": true
        },
        "traces": {
            "enabled": true
        }
    },
    "upload_source_maps": true
}
